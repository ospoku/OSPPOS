
@using DMX.Models;  
@using DMX.ViewComponents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Web
@using Microsoft.AspNetCore.DataProtection
@using OSPPOS.Models
@using OSPPOS.ViewComponents
@inject UserManager<AppUser> usm;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IEnumerable<OSPPOS.ViewModels.ViewProductsVM>;
@inject Microsoft.AspNetCore.DataProtection.IDataProtectionProvider DataProtectionProvider

@{
    // Optional: create protector in view (same purpose string)
    var protector = DataProtectionProvider.CreateProtector("IdProtector");
  
}
<div class="tab-content tab-content-dim" id="myTabContent">
    <!-- TAB 1: USERS -->
    <div class="tab-pane fade show active tab-pane-dim" id="users" role="tabpanel">
        <div class="tab-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-semibold mb-0"><i class="bi bi-tags me-2"></i>Products</h6>
                <button class="btn btn-primary btn-sm" id="openFormBtn2" onclick="document.getElementById('AddProductDialog').showModal()">
                    <i class="bi bi-plus-circle me-1"></i>Add User
                </button>
            </div>
            <!-- DATATABLES -->
            <div class="table-container">
            <table class="table darkTable" id="userTable">
                <thead>
                    <tr>
                    <th>SN</th>
                    <th>SKU</th>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Unit</th>
                    <th class="text-end">Cost</th>
                    <th class="text-end">Sell Price</th>
                    <th class="text-end">Wholesale</th>
                    <th class="text-end">Margin</th>
                    <th class="text-center">Reorder</th>
                    <th class="text-center">Stock</th>
               
                     
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                  
  @foreach (var p in Model)
                {
                            <tr class="@(p.IsLowStock ? "table-warning" : "")">
                              
                        <td></td>
                        <td class="text-muted small">@(p.SKU ?? "—")</td>
                        <td class="ellipsed-text">
                            <span class="fw-semibold">@p.Name</span>
                            @if (!p.IsActive)
                            {
                                <span class="badge bg-secondary ms-1">Inactive</span>
                            }
                        </td>
                        <td>
                @p.Category
                        </td>
                        <td class="small">@p.Unit</td>
                        <td class="text-end">@p.CostPrice.ToString("N2")</td>
                        <td class="text-end fw-semibold">@p.SellingPrice.ToString("N2")</td>
                        <td class="text-end">@p.WholesalePrice.ToString("N2")</td>
                        <td class="text-end">
                            <span class="@(p.ProfitMargin > 20 ? "text-success" : p.ProfitMargin > 10 ? "text-warning" : "text-danger")">
                                @p.ProfitMargin.ToString("N1")%
                            </span>
                        </td>
                        <td class="text-center small">@p.ReorderLevel</td>
                        <td class="text-center">
                            @if (p.CurrentStock == 0)
                            {
                                <span class="badge bg-danger">Out</span>
                            }
                            else if (p.IsLowStock)
                            {
                                <span class="badge bg-warning text-dark">@p.CurrentStock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@p.CurrentStock</span>
                            }
                        </td>
                           <td>

                                <div class="btn-group" role="group">
                                    <button id="btnGroupDrop1" type="button" class="btn btn-sm btn-rounded btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        Select Action
                                    </button>

                                   <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                                    @if(p.CanEdit)
                                    {

                                        <button  onclick="openDialogFromData(this)" data-url="EditProduct" data-user-id="@protector.Protect(p.PublicId.ToString())" data-dialog-id="EditProductDialog" class="dropdown-item-custom"><i style="width:15px; height:15px" class=" fa fa-edit mr-3 text-warning"></i>Edit</button>
                                        }

                                    

                                       @if(p.CanPrint)
                                       {

                                        <button type="button" class="dropdown-item-custom" onclick="printMemoIframe('@protector.Protect(p.PublicId.ToString())')">
                                            <i style="width:15px; height:15px" class="fa fa-print mr-3 text-primary"></i>Print
                                        </button>
                                       }
 
                                             
                                                <button type="button" onclick="de" class="dropdown-item-custom"><i style="width:15px; height:15px" class="fa fa-trash mr-3 text-danger"></i>Delete</button>
                                          
                                  </div> 
                        </div>

                        </td>
                    </tr>
             }
                </tbody>
            </table>
       </div>
    

    
    <div class="card-footer rounded-bottom-5 border-0 text-muted small">
        <span>@Model.Count().ToString() product(s) &nbsp;|&nbsp;</span>
        Stock cost value: <strong>GHS @Model.Sum(p => p.CurrentStock * p.CostPrice).ToString("N2")</strong> &nbsp;|&nbsp;
        Retail value: <strong>GHS @Model.Sum(p => p.CurrentStock * p.SellingPrice).ToString("N2")</strong>
            </div>
</div>
</div>
</div>
