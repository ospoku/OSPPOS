        /* Dialog styling */
        #AddProductDialog {
            max-width: 900px;
            width: 100%;
            border: none;
            border-radius: 12px;
            padding: 0;
            background: #fff;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from

        {
            opacity: 0;
            transform: translateY(-30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        #AddProductDialog::backdrop {
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
        }

        /* Modal header */
        .modal-header-custom {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid #e9ecef;
            border-radius: 12px 12px 0 0;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

            .modal-header-custom h6 {
                color: #333;
                font-weight: 600;
                margin: 0;
            }

                .modal-header-custom h6 i {
                    color: #0d6efd;
                    margin-right: 8px;
                }

        /* Modal body */
        .modal-body-custom {
            padding: 1.5rem;
            max-height: 70vh;
            overflow-y: auto;
        }

        /* Modal footer */
        .modal-footer-custom {
            padding: 1rem 1.5rem;
            border-top: 1px solid #e9ecef;
            border-radius: 0 0 12px 12px;
            background: #f8f9fa;
        }

        /* Floating label styles */
        .did-floating-label-content {
            position: relative;
            margin-bottom: 1.5rem;
        }

        .did-floating-input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            background: #fafafa;
        }

            .did-floating-input:focus {
                border-color: #0d6efd;
                outline: 0;
                background: white;
                box-shadow: 0 0 0 3px rgba(13, 110, 253, 0.1);
            }

        .did-floating-label {
            position: absolute;
            top: -10px;
            left: 12px;
            background: #fff;
            padding: 0 6px;
            font-size: 0.8rem;
            color: #6c757d;
            pointer-events: none;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        /* Card styles */
        .card-custom {
            border: 1px solid #e9ecef;
            border-radius: 10px;
            background: white;
            transition: box-shadow 0.3s ease;
        }

            .card-custom:hover {
                box-shadow: 0 5px 20px rgba(0,0,0,0.06);
            }

        .card-header-custom {
            padding: 0.75rem 1rem;
            background: transparent;
            border-bottom: 1px solid #e9ecef;
        }

            .card-header-custom h6 {
                font-weight: 600;
                color: #495057;
                margin: 0;
            }

        .card-body-custom {
            padding: 1rem;
        }

        /* Button styles */
        .btn-close-custom {
            border: 1.5px solid #dc3545;
            background: transparent;
            color: #dc3545;
            padding: 5px 15px;
            border-radius: 50px;
            font-size: 13px;
            transition: all 0.3s ease;
        }

            .btn-close-custom:hover {
                background: #dc3545;
                color: white;
            }

        .btn-save-custom {
            border: 1.5px solid #0d6efd;
            background: transparent;
            color: #0d6efd;
            padding: 10px 35px;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-save-custom:hover {
                background: #0d6efd;
                color: white;
                box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3);
            }

        /* Margin display */
        .margin-display {
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            padding: 10px;
            border-radius: 8px;
            text-align: center;
        }

        /* Checkbox style */
        .form-check-input:checked {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        /* Scrollbar styling */
        .modal-body-custom::-webkit-scrollbar {
            width: 6px;
        }

        .modal-body-custom::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }

        .modal-body-custom::-webkit-scrollbar-thumb {
            background: #c1c7cd;
            border-radius: 10px;
        }

            .modal-body-custom::-webkit-scrollbar-thumb:hover {
                background: #a8b0b8;
            }

        /* Dialog open state */
        dialog[open] {
            display: block;
        }
    </style>


