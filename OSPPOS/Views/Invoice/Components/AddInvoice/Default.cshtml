            flex-wrap: wrap;
            gap: 8px;
            flex-shrink: 0;
            transition: background 0.3s, border-color 0.3s;
        }

        body.light-mode .sale-footer {
            background: #fafbfc;
            border-color: #e9ecef;
        }

        .footer-hint {
            font-size: 0.75rem;
            color: #6a6f80;
        }

        body.light-mode .footer-hint {
            color: #868e96;
        }

        .footer-actions {
            display: flex;
            gap: 8px;
        }

            .footer-actions .btn {
                padding: 7px 20px;
                font-size: 0.85rem;
                font-weight: 500;
                border-radius: 8px;
                transition: all 0.2s;
                cursor: pointer;
                border: none;
            }

            .footer-actions .btn-outline-secondary {
                border: 1px solid #3d424a;
                background: transparent;
                color: #b0b5c8;
            }

        body.light-mode .footer-actions .btn-outline-secondary {
            border-color: #dee2e6;
            color: #495057;
        }

        .footer-actions .btn-outline-secondary:hover {
            background: #2d323a;
            border-color: #6a6f80;
        }

        body.light-mode .footer-actions .btn-outline-secondary:hover {
            background: #f1f3f5;
            border-color: #adb5bd;
        }

        .footer-actions .btn-success {
            background: #2d8a4e;
            color: white;
            padding: 7px 24px;
        }

            .footer-actions .btn-success:hover:not(:disabled) {
                background: #23703f;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(45, 138, 78, 0.3);
            }

            .footer-actions .btn-success:disabled {
                opacity: 0.4;
                cursor: not-allowed;
                transform: none;
            }

        /* ── Sale Type Toggle ───────────────────────────────────────── */
        .sale-type-toggle {
            display: flex;
            gap: 8px;
            background: #1a1e26;
            padding: 4px;
            border-radius: 10px;
            flex-shrink: 0;
            transition: background 0.3s;
        }

        body.light-mode .sale-type-toggle {
            background: #f1f3f5;
        }

        .sale-type-btn {
            flex: 1;
            padding: 7px 16px;
            border: 2px solid transparent;
            border-radius: 8px;
            background: transparent;
            font-weight: 600;
            font-size: 0.8rem;
