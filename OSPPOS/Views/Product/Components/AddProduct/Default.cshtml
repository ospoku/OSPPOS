@model OSPPOS.ViewModels.AddProductVM;

<dialog id="AddProductDialog" class="col-md-8 border-0 rounded p-0">
    <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">   <i class="fas fa-fw fa-file-alt"></i>Add Product</h6>
        <button type="button" aria-label="Close"
                class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddProductDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddProduct", "Product", FormMethod.Post, new { id = "addProductForm" }))
    {
        <div class="modal-body">
            <!-- Memo Title -->
    
 
       
       
     
        @*    
            <div class="input-group">
  <!-- Left icon addon -->
  <div class="input-group-text">
    <!-- Use any icon here: Font Awesome, SVG, emoji, etc. -->
    <i class="fas fa-heading"></i>          <!-- example: user icon -->
    <!-- or SVG: <svg ...> ... </svg> -->
    <!-- or just text/emoji: 👤 -->
  </div>

  <!-- Floating label + input -->
  <div class="did-floating-label-content">
                    <input type="text" asp-for="@Model.Notes"
      class="did-floating-input" 
      id="title" 
      placeholder=" "           
    />
    <label class="did-floating-label" for="title">Title</label>
  </div>
</div> *@

          

 
            <div class="row g-3">
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Product Details</h6>
                        </div>
                        <div class="card-body">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                            <div class="row g-3">
                                <div class="did-floating-label-content col-md-8">

                                    <input name="Name" type="text" class="did-floating-input" placeholder="" required /> <label class="did-floating-label">Product Name<span class="text-danger">*</span></label>
                                </div>
                                <div class="did-floating-label-content col-md-4">
                                    <input name="SKU" type="text" class="did-floating-input" placeholder="" />
                                    <label class="did-floating-label">SKU / Code</label>
                               
                                </div>
                                <div class="col-md-4">


                                    <select id="selectMemoUser" class="dmx-choices"><option value="">Select Category</option></select>
                                </div>
                                <div class="col-md-4">
                                    <select id="selectMemoUser" class="dmx-choices"><option value="">Select Supplier</option></select>
                                </div>
                                <div class="col-md-4">
                                    <select id="selectMemoUser" class="dmx-choices"><option value="">Select Unit</option></select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <textarea name="Description" class="form-control dmx-textarea" rows="2"
                                          placeholder="Optional notes about this product"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm mb-3">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Pricing</h6>
                        </div>
                        <div class="card-body">
                            <div class="did-floating-label-content mb-3">
                              
                                <input name="CostPrice" type="number" step="0.01" min="0" class="did-floating-input"
                                       placeholder="0.00" id="costPrice" oninput="calcMargin()" required /> 
                                       <label class="did-floating-label">Cost Price (GHS) <span class="text-danger">*</span></label>
                            </div>
                            <div class="did-floating-label-content mb-3">
                                <input name="SellingPrice" type="number" step="0.01" min="0" class="did-floating-input"
                                       placeholder="0.00" id="sellPrice" oninput="calcMargin()" required /> 
                                       <label class="did-floating-label">Selling Price (GHS) <span class="text-danger">*</span></label>
                            </div>
                            <div class="did-floating-label-content  mb-3">
                                <input name="WholesalePrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" placeholder="0.00" /> <label class="did-floating-label">Wholesale Price (GHC)</label>
                            </div>
                            <div class="p-2 rounded bg-light text-center small">
                                Margin: <strong id="marginDisplay">—</strong>
                            </div>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Stock Settings</h6>
                        </div>
                        <div class="card-body">
                            <div class="did-floating-label-content mb-3">
                           
                                <input name="CurrentStock" type="number" min="0" class="did-floating-input" placeholder=""
                                       value="0" />     <label class="did-floating-label">Opening Stock</label>
                            </div>
                            <div class="did-floating-label-content mb-3">
                                <input name="ReorderLevel" type="number" min="0" class="did-floating-input"
                                       value="10" />    
                                       
                                       <label class="did-floating-label">Reorder Level</label>
                                <div class="form-text">Alert when stock drops to this level.</div>
                            </div>
                            <div class="form-check mb-3">
                                <input name="IsActive" type="checkbox" class="form-check-input" id="isActive"
                                       value="true" checked />
                                <label class="form-check-label" for="isActive">Active product</label>
                            </div>
@*                             <button type="submit" class="btn btn-outline-success w-100">
                                <i class="bi bi-check-circle me-2"></i>Save Product
                            </button> *@
                        </div>
                    </div>
                </div>
            </div>



            <script>
                function calcMargin() {
                    const cost = parseFloat(document.getElementById('costPrice').value) || 0;
                    const sell = parseFloat(document.getElementById('sellPrice').value) || 0;
                    const el = document.getElementById('marginDisplay');
                    if (sell > 0 && cost > 0) {
                        const m = ((sell - cost) / sell * 100).toFixed(1);
                        el.textContent = m + '%';
                        el.style.color = m > 20 ? '#198754' : m > 10 ? '#fd7e14' : '#dc3545';
                    } else {
                        el.textContent = '—';
                        el.style.color = '';
                    }
                }
            </script>
            

         </div>
         <div class="modal-footer">
          
        <button id="saveButton"  class="btn btn-sm btn-outline-primary rounded-5">Save</button>
        </div>

     
            }
   
    
   
   
      
    
    </dialog>
    
          


  
