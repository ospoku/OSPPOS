@using OSPPOS.Models
@model OSPPOS.ViewModels.AddInvoiceVM;

@* <dialog id="AddInvoiceDialog">


    <div class="modal-header border-bottom px-3 py-2">
        <h6 class="m-0 fw-semibold">
            <i class="fas fa-cash-register me-2 text-success"></i>New Sale
        </h6>
        <button type="button"
                class="btn btn-sm btn-outline-danger"
