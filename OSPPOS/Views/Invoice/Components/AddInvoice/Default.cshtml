        }

        .sale-type-btn.text-success {
            color: #2d8a4e;
            border-color: #2d8a4e;
            background: #1a1e26;
        }

        body.light-mode .sale-type-btn.text-success {
            background: #ffffff;
        }

        .sale-type-btn.text-warning {
            color: #f59f00;
            border-color: #f59f00;
            background: #1a1e26;
        }

        body.light-mode .sale-type-btn.text-warning {
            background: #ffffff;
        }

        .sale-type-btn.text-muted {
            color: #6a6f80;
        }

        body.light-mode .sale-type-btn.text-muted {
            color: #6c757d;
        }

        .hidden {
            display: none !important;
        }

        /* ── Responsive ───────────────────────────────────────────────── */
        @@media (max-width: 992px) {
            .sale-body

        {
            grid-template-columns: 1fr;
            gap: 16px;
            padding: 16px 18px;
        }

        .sale-right {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px;
        }

        }

        @@media (max-width: 768px) {
            dialog

        {
            width: 100vw;
            height: 100vh;
            max-height: 100vh;
