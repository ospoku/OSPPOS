<!-- Main table -->
<div class="card rounded-5 shadow mb-4">
    <div class="card-header py-3  d-flex justify-content-between align-items-center">
        <span class="fw-semibold" style="font-size:.85rem">
            All products — stock position
        </span>
        <span class="text-muted" style="font-size:.78rem">
            As at @DateTime.Today.ToString("dd MMM yyyy") &middot; @Model.Products.Count items
        </span>
    </div>
    <div class="card-body">
    
        <table class="table dataTables_wrapper align-middle mb-0" style="font-size:.85rem">
            <thead class="table-light">
                <tr>
                    <th style="width:80px">SKU</th>
                    <th>Product</th>
                    <th>Type</th>
                    <th class="text-center" style="width:70px">Reorder</th>
                    <th class="text-center" style="width:80px">In stock</th>
                    <th style="min-width:140px">Level</th>
                    <th class="text-end">Cost value</th>
                    <th class="text-end">Retail value</th>
                    <th style="width:80px">Status</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @{
                    var grouped = @Model.Products.GroupBy(p => p.Category?.Name ?? "Uncategorised")
                        .OrderBy(g => g.Key);
                }

                @foreach (var group in grouped)
                {
                    <!-- Category group header -->
                    <tr style="background:var(--bs-secondary-bg)">
                        <td colspan="10"
                            class="text-uppercase fw-semibold"
                            style="font-size:.72rem; letter-spacing:.05em; color:#6c757d; padding:6px 14px">
                            <i class="fas fa-folder me-1"></i>@group.Key
                            <span class="fw-normal ms-1">(@group.Count() products)</span>
                        </td>
                    </tr>

                    @foreach (var p in group.OrderBy(p => p.Name))
                    {
                        var pct    = maxStock > 0 ? (int)((p.CurrentStock / maxStock) * 100) : 0;
                        var barCls = p.CurrentStock == 0 ? "bg-danger"
                                   : p.IsLowStock        ? "bg-warning"
                                   : "bg-success";
                        var rowCls = p.CurrentStock == 0 ? "table-danger"
                                   : p.IsLowStock        ? "table-warning"
                                   : "";

                        <tr class="@rowCls">
                            <td class="text-muted" style="font-size:.78rem">@(p.SKU ?? "—")</td>

                            <td>
                                <span class="fw-semibold">@p.Name</span>
                                <span class="text-muted ms-1" style="font-size:.75rem">@p.Unit</span>
                            </td>

                            <td>
                        @*         @if (p.Category?.Type == "Hard")
                                {
                                    <span class="badge rounded-pill"
                                          style="background:#FAECE7;color:#712B13;font-size:.7rem">Hard</span>
                                } *@
                         @*        else
                                {
                                    <span class="badge rounded-pill"
                                          style="background:#E6F1FB;color:#0C447C;font-size:.7rem">Soft</span>
                                } *@
                            </td>

                            <td class="text-center text-muted">@p.ReorderLevel</td>

                            <td class="text-center fw-semibold
                                @(p.CurrentStock == 0 ? "text-danger"
                                : p.IsLowStock        ? "text-warning"
                                : "")">
                                @p.CurrentStock
                            </td>

                            <!-- Progress bar + % -->
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="flex-grow-1 rounded"
                                         style="background:#e9ecef;height:6px;min-width:60px">
                                        <div class="rounded @barCls"
                                             style="height:6px;width:@(Math.Min(pct,100))%"></div>
                                    </div>
                                    <span class="text-muted" style="font-size:.72rem;min-width:28px">
                                        @(p.CurrentStock == 0 ? "Out" : pct + "%")
                                    </span>
                                </div>
                            </td>

                            <td class="text-end text-muted" style="font-size:.8rem">
                                GHS @((p.CurrentStock * p.CostPrice).ToString("N2"))
                            </td>
                            <td class="text-end fw-semibold">
                                GHS @((p.CurrentStock * p.SellingPrice).ToString("N2"))
                            </td>

                            <!-- Status badge -->
                            <td>
                                @if (p.CurrentStock == 0)
                                {
                                    <span class="badge rounded-pill"
                                          style="background:#FCEBEB;color:#791F1F;font-size:.7rem">Out</span>
                                }
                                else if (p.IsLowStock)
                                {
                                    <span class="badge rounded-pill"
                                          style="background:#FAEEDA;color:#633806;font-size:.7rem">Low</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill"
                                          style="background:#EAF3DE;color:#27500A;font-size:.7rem">OK</span>
                                }
                            </td>

                            <!-- Actions -->
                            <td>
                                <div class="d-flex gap-1">
                                    @if (p.CurrentStock == 0)
                                    {
                                        <a asp-controller="Stock" asp-action="Create"
                                           class="btn btn-sm btn-primary px-2" title="Restock now">
                                            <i class="fas fa-truck-loading"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-action="Movement" asp-route-id="@p.Id"
                                           class="btn btn-sm btn-outline-secondary px-2"
                                           title="Stock movement">
                                            <i class="fas fa-exchange-alt"></i>
                                        </a>
                                    }
                                    <a asp-controller="Products" asp-action="Edit"
                                       asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-secondary px-2" title="Edit">
                                        <i class="fas fa-pencil-alt"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }

           
            </tbody>

            <tfoot class="table-light" style="font-size:.8rem">
                <tr>
                    <td colspan="6" class="text-muted">
                        Showing @Model.Products.Count product(s)
                    </td>
                    <td class="text-end fw-semibold">GHS @totalCost.ToString("N2")</td>
                    <td class="text-end fw-semibold">GHS @totalRetail.ToString("N2")</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
   
    <!-- Legend -->
    <div class="card-footer  d-flex justify-content-between align-items-center"
         style="font-size:.78rem">
        <div class="d-flex gap-3 text-muted">
            <span>
                <span class="d-inline-block rounded me-1"
                      style="width:10px;height:10px;background:#FCEBEB;border:0.5px solid #F09595"></span>
                Out of stock
            </span>
            <span>
                <span class="d-inline-block rounded me-1"
                      style="width:10px;height:10px;background:#FFF3CD;border:0.5px solid #EF9F27"></span>
                Low stock
            </span>
            <span>
                <span class="d-inline-block rounded me-1"
                      style="width:10px;height:10px;background:#fff;border:0.5px solid #ccc"></span>
                OK
            </span>
        </div>
        <div class="text-muted">
            <i class="fas fa-exchange-alt me-1"></i>= movement history
        </div>
    </div>
</div>

