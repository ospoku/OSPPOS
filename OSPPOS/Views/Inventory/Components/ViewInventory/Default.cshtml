
@using DMX.Models;  
@using DMX.ViewComponents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Web
@using Microsoft.AspNetCore.DataProtection
@using OSPPOS.Models
@using OSPPOS.ViewComponents
@inject UserManager<AppUser> usm;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model OSPPOS.ViewModels.ViewInventoryVM
@inject Microsoft.AspNetCore.DataProtection.IDataProtectionProvider DataProtectionProvider

@{
    // Optional: create protector in view (same purpose string)
    var protector = DataProtectionProvider.CreateProtector("IdProtector");
  
}
<div class="card shadow mb-4">
    <div class="card-header py-3"><i class="fas fa-fw fa-file-alt"></i>
        <h6 class="m-0 font-weight-bold text-primary d-inline">Memos</h6>
        
          
        <button id="btnAddMemo" class="btn btn-sm btn-rounded  btn-outline-primary fa-pull-right" onclick="document.getElementById('AddMemoDialog').showModal()"><i class="fa fa-fw fa-plus-circle"></i>Add Memo</button>
        </div>
        <div class="card-body">
         
            <table class="table dataTables_wrapper">
            <thead>
                <tr>
                    <th>SN</th>
                    <th>SKU</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Supplier</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int sn = 1;
                }

                @foreach (var product in @Model.Products)
                {
                    <tr>
                        <td>@sn++</td>
                        <td>@product.SKU</td>
                        <td>@product.Name</td>
                        <td>@product.Category?.Name</td>
                        <td>@product.Supplier?.Name</td>
                        <td>
                            <div class="btn-group">
                                <button class="btn btn-sm btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown">
                                    Action
                                </button>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="#">Edit</a>
                                    <a class="dropdown-item text-danger" href="#">Delete</a>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
          
       </div>
       </div>

    <div class="card-footer">
    </div>


<iframe id="printFrame" style="display:none;"></iframe>

<script type="text/javascript">
    function printMemoIframe(memoId) {
        const printFrame = document.getElementById('printFrame');
        printFrame.src = `/Memo/PrintMemo?Id=${memoId}`;
        printFrame.onload = function () {
            printFrame.contentWindow.focus();
            printFrame.contentWindow.print();
        };
    }

</script>

@await Component.InvokeAsync(nameof(AddProduct))
<dialog id="EditMemoDialog"><div id="EditMemoDialogContent"></div></dialog>
<dialog id="CommentMemoDialog" class="col-md-6 border-0 rounded p-0"><div id="CommentMemoDialogContent"></div></dialog>