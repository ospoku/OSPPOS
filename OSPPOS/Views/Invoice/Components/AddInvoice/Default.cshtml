        /* ── Dialog Sizing Helper ─────────────────────────────────────── */
        @@media (min-height: 800px) and (min-width: 1200px) {
            dialog

        {
            width: min(85vw, 1100px);
            height: min(85vh, auto);
            max-height: 85vh;
        }}

        
