    <script>
        // Sidebar controls
        let isCollapsed = false;
        let isMobileOpen = false;

        function toggleSidebar() {
            isCollapsed = !isCollapsed;
            const sidebar = document.getElementById('sidebar');
            const logoText = document.getElementById('logoText');
            const toggleIcon = document.getElementById('toggleIcon');
            if (isCollapsed) {
                sidebar.classList.add('sidebar-collapsed');
                logoText.style.opacity = '0';
                toggleIcon.classList.replace('fa-bars', 'fa-bars-staggered');
            } else {
                sidebar.classList.remove('sidebar-collapsed');
                logoText.style.opacity = '1';
                toggleIcon.classList.replace('fa-bars-staggered', 'fa-bars');
            }
        }

        function toggleMobileSidebar() {
            isMobileOpen = !isMobileOpen;
            document.getElementById('sidebar').classList.toggle('open', isMobileOpen);
        }

        function setActive(el) {
            document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
            el.classList.add('active');
        }

        // Notification System
        let notifications = JSON.parse(localStorage.getItem('notifications')) || [];

        function saveNotifications() {
            localStorage.setItem('notifications', JSON.stringify(notifications));
        }

        function updateNotificationCount() {
            const unread = notifications.filter(n => !n.read).length;
            const countEl = document.getElementById('notificationCount');
            countEl.textContent = unread || '';
            countEl.style.display = unread ? 'flex' : 'none';
        }

        function showMessage(text, type = 'info', title = '') {
            const toast = document.createElement('div');
            const bg = type === 'success' ? 'bg-green-600' : type === 'error' ? 'bg-red-600' : type === 'warning' ? 'bg-yellow-600' : 'bg-blue-600';

            toast.className = `px-6 py-4 rounded-2xl shadow-2xl flex items-start gap-3 w-80 text-white ${bg}`;
            toast.innerHTML = `
                <i class="fa-solid ${type==='success'?'fa-check-circle':type==='error'?'fa-xmark-circle':type==='warning'?'fa-triangle-exclamation':'fa-info-circle'} mt-0.5"></i>
                <div class="flex-1">
                    ${title ? `<div class="font-semibold">${title}</div>` : ''}
                    <div>${text}</div>
                </div>
            `;
            document.getElementById('toastContainer').appendChild(toast);

            notifications.unshift({
                id: Date.now(),
                title: title || type.charAt(0).toUpperCase() + type.slice(1),
                message: text,
                type,
                timestamp: new Date().toISOString(),
                read: false
            });

            saveNotifications();
            updateNotificationCount();
            renderNotifications();

            setTimeout(() => {
                toast.style.transition = 'all 0.3s';
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(20px)';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        function renderNotifications() {
            const container = document.getElementById('notificationList');
            container.innerHTML = notifications.length === 0
                ? `<div class="p-8 text-center text-gray-500">No notifications</div>`
                : '';

            notifications.forEach((notif, i) => {
                const div = document.createElement('div');
                div.className = `p-4 rounded-2xl mx-2 mb-2 cursor-pointer ${notif.read ? 'opacity-70' : 'bg-gray-800/60'}`;
                div.innerHTML = `
                    <div class="flex gap-3">
                        <i class="fa-solid ${notif.type==='success'?'fa-check-circle text-green-400':notif.type==='error'?'fa-xmark-circle text-red-400':notif.type==='warning'?'fa-triangle-exclamation text-yellow-400':'fa-info-circle text-blue-400'}"></i>
                        <div class="flex-1">
                            <div class="font-medium">${notif.title}</div>
                            <div class="text-sm text-gray-400">${notif.message}</div>
                            <div class="text-xs text-gray-500 mt-1">${new Date(notif.timestamp).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</div>
                        </div>
                    </div>
                `;
                div.onclick = () => {
                    notifications[i].read = true;
                    saveNotifications();
                    updateNotificationCount();
                    renderNotifications();
                };
                container.appendChild(div);
            });
        }

        function toggleNotifications() {
            const panel = document.getElementById('notificationPanel');
            panel.classList.toggle('hidden');
            if (!panel.classList.contains('hidden')) renderNotifications();
        }

        function showMessagesPanel() {
            toggleNotifications();
        }

        function markAllRead() {
            notifications.forEach(n => n.read = true);
            saveNotifications();
            updateNotificationCount();
            renderNotifications();
        }

        function clearAllNotifications() {
            if (confirm("Clear all notifications?")) {
                notifications = [];
                saveNotifications();
                updateNotificationCount();
                renderNotifications();
            }
        }

        // Shutdown
        function confirmShutdown() {
            document.getElementById('shutdownModal').classList.remove('hidden');
        }

        function cancelShutdown() {
            document.getElementById('shutdownModal').classList.add('hidden');
        }

        function performShutdown() {
            cancelShutdown();
            showMessage("Initiating system shutdown...", "info");

            setTimeout(() => {
                const shutdownScreen = document.createElement('div');
                shutdownScreen.className = "fixed inset-0 bg-black z-[999] flex items-center justify-center flex-col gap-6";
                shutdownScreen.innerHTML = `
                    <i class="fa-solid fa-power-off text-red-500 text-7xl animate-pulse"></i>
                    <h1 class="text-4xl font-bold">Shutting Down...</h1>
                    <p class="text-gray-400">Please wait</p>
                `;
                document.body.appendChild(shutdownScreen);

                setTimeout(() => {
                    shutdownScreen.innerHTML = `
                        <i class="fa-solid fa-check-circle text-green-500 text-7xl"></i>
                        <h1 class="text-4xl font-bold">Shutdown Complete</h1>
                        <p class="text-gray-400 mt-2">You can safely close this window.</p>
                    `;
                }, 2200);
            }, 600);
        }

        // Close notification panel when clicking outside
        document.addEventListener('click', (e) => {
            const panel = document.getElementById('notificationPanel');
            if (panel && !panel.classList.contains('hidden') &&
                !e.target.closest('#notificationPanel') &&
                !e.target.closest('button[onclick="toggleNotifications()"]')) {
                panel.classList.add('hidden');
            }
        });

        // Init
        window.onload = () => {
            updateNotificationCount();
            renderNotifications();
        };
    </script>
