{
  "version": "3.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "font-awesome@7.0.1",
      "destination": "wwwroot/lib/font-awesome/"
    },
    {
      "library": "tom-select@2.4.3",
      "destination": "wwwroot/lib/tom-select/"
    },
    {
      "provider": "unpkg",
      "library": "@fontsource/roboto-mono@5.2.9",
      "destination": "wwwroot/lib/fontsource/roboto-mono/"
    },
    {
      "library": "bootstrap@5.3.8",
      "destination": "wwwroot/lib/bootstrap/"
    },
    {
      "library": "tailwindcss@4.3.0",
      "destination": "wwwroot/css/tailwindcss/"
    },
    {
      "library": "bootstrap-icons@1.13.1",
      "destination": "wwwroot/icons/bootstrap-icons/"
    },
    {
      "library": "datatables.net-bs5@2.3.8",
      "destination": "wwwroot/lib/datatables.net-bs5/"
    },
    {
      "library": "datatables.net-rowgroup-bs5@1.6.0",
      "destination": "wwwroot/lib/datatables.net-rowgroup-bs5/"
    },
    {
      "library": "datatables.net-rowgroup@1.6.0",
      "destination": "wwwroot/lib/datatables.net-rowgroup/"
    }
  ]
}