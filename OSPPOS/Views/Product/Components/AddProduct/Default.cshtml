    <script>
        
        function calcMargin() {
            const cost = parseFloat(document.getElementById('costPrice').value) || 0;
            const sell = parseFloat(document.getElementById('sellPrice').value) || 0;
            const el = document.getElementById('marginDisplay');
            if (sell > 0 && cost > 0) {
                const m = ((sell - cost) / sell * 100).toFixed(1);
                el.textContent = m + '%';
                el.style.color = m > 20 ? '#51cf66' : m > 10 ? '#ffd43b' : '#ff6b6b';
            } else {
                el.textContent = '—';
                el.style.color = '#e4e6eb';
            }
        }

        // Trigger initial calculation
        document.addEventListener('DOMContentLoaded', function() {
            calcMargin();
        });

        // Close dialog on escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                const dialog = document.getElementById('AddProductDialog');
                if (dialog.open) {
                    dialog.close();
                }
            }
        });


    let grnLineIndex = 2; // Start after sample rows

    const grnProductOptions = [
        '<option value="">Select product</option>',
        '<option value="1">Premium Coffee Beans</option>',
        '<option value="2">Organic Green Tea</option>',
        '<option value="3">Dark Chocolate Bar</option>',
        '<option value="4">Almond Milk</option>',
        '<option value="5">Vanilla Extract</option>',
        '<option value="6">Coconut Oil</option>',
        '<option value="7">Honey</option>',
        '<option value="8">Cinnamon Sticks</option>',
    ].join('');

    function addLine() {
        const empty = document.getElementById('emptyRow');
        if (empty) empty.remove();

        const row = document.createElement('tr');
        row.innerHTML = `
            <td>
                <select class="form-select form-select-dark choices-select" data-placeholder="Search products...">
                    ${grnProductOptions}
                </select>
            </td>
            <td>
                <input type="number" min="1" value="1" class="form-control form-control-dark text-end" oninput="calcTotal(this)" />
            </td>
            <td>
                <input type="number" step="0.01" min="0" value="0.00" class="form-control form-control-dark text-end" oninput="calcTotal(this)" />
            </td>
            <td class="text-end fw-semibold">
                <span class="line-total">0.00</span>
            </td>
            <td>
                <input type="date" class="form-control form-control-dark" />
            </td>
            <td class="text-center">
                <input type="checkbox" class="form-check-input form-check-input-dark" checked />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger-custom px-2" onclick="removeLine(this)">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </td>`;

        document.getElementById('lineItems').appendChild(row);
        grnLineIndex++;

 

        updateBatchTotal();
    }

    function removeLine(btn) {
        const row = btn.closest('tr');
        const select = row.querySelector('.choices-select');

        // Clean up Choices instance
        if (select && select._choicesInstance) {
            select._choicesInstance.destroy();
            delete select._choicesInstance;
        }

        row.remove();

        const tbody = document.getElementById('lineItems');
        const remaining = tbody.querySelectorAll('tr');

        if (!remaining.length) {
            const tr = document.createElement('tr');
            tr.id = 'emptyRow';
            tr.innerHTML = `
                <td colspan="7" class="text-center text-muted py-4 small">
                    <i class="fas fa-box-open d-block mb-1" style="font-size:1.4rem"></i>
                    No products added yet — click "Add line" to start
                </td>`;
            tbody.appendChild(tr);
        }

        updateBatchTotal();
    }

    function calcTotal(input) {
        const row = input.closest('tr');
        const qty = parseFloat(row.querySelector('input[type="number"]').value) || 0;
        const cost = parseFloat(row.querySelectorAll('input[type="number"]')[1].value) || 0;
        row.querySelector('.line-total').textContent = (qty * cost).toFixed(2);
        updateBatchTotal();
    }

    function updateBatchTotal() {
        const totals = document.querySelectorAll('.line-total');
        let sum = 0;
        totals.forEach(el => {
            sum += parseFloat(el.textContent || 0);
        });
        document.getElementById('batchTotal').textContent = 'GHS ' + sum.toFixed(2);
    }

    function validateAndSaveGRN() {
        const errors = [];

        const supplier = document.getElementById('grnSupplier');
        const supplierValue = supplier ? supplier.value : '';
        if (!supplierValue) errors.push('Please select a supplier.');

        const rows = document.querySelectorAll('#lineItems tr');
        const visibleRows = Array.from(rows).filter(r => r.id !== 'emptyRow');

        if (!visibleRows.length) errors.push('Please add at least one product.');

        visibleRows.forEach((row, i) => {
            const select = row.querySelector('.choices-select');
            const product = select ? select.value : '';
            const qtyInput = row.querySelector('input[type="number"]');
            const costInput = row.querySelectorAll('input[type="number"]')[1];
            const qty = qtyInput ? parseFloat(qtyInput.value) || 0 : 0;
            const cost = costInput ? parseFloat(costInput.value) || 0 : 0;

            if (!product) errors.push(`Line ${i + 1}: please select a product.`);
            if (qty < 1) errors.push(`Line ${i + 1}: quantity must be at least 1.`);
            if (cost <= 0) errors.push(`Line ${i + 1}: unit cost must be greater than 0.`);
        });

        if (errors.length > 0) {
            const list = document.getElementById('grn-error-list');
            list.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
            document.getElementById('grn-errors').style.display = 'block';
            return;
        }

        document.getElementById('grn-errors').style.display = 'none';
        alert('✅ GRN saved successfully! (Demo)');
        document.getElementById('AddStockBatchDialog').close();
    }



        // Recalculate totals
        updateBatchTotal();

        // Handle dialog open/close for cleanup
      
    

  
</script>


