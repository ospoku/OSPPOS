@model OSPPOS.ViewModels.AddSaleVM;

<dialog id="AddSaleDialog" class="col-md-6 border-0 rounded p-0">
    @* <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">   <i class="fas fa-fw fa-file-alt"></i>Add Sale</h6>
        <button type="button" aria-label="Close"
                class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddMemoDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddSale", "Sale", FormMethod.Post, new { id = "addSaleForm" }))
