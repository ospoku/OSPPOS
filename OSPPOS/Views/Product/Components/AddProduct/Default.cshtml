@model OSPPOS.ViewModels.AddProductVM

<dialog id="AddProductDialog" class="border-0 rounded p-0">
    <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-file-alt"></i>Add Product
        </h6>
        <button type="button" class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddProductDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddProduct", "Product", FormMethod.Post, new { id = "addProductForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <div class="row g-3">
                <div class="col-lg-8">
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Product Details</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="did-floating-label-content col-md-8">
                                    <input asp-for="Name" type="text" class="did-floating-input" placeholder="" required/>
                                    <label class="did-floating-label">Product Name <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                                <div class="did-floating-label-content col-md-4">
                                    <input asp-for="SKU" type="text" class="did-floating-input" placeholder="" />
                                    <label class="did-floating-label">SKU / Code</label>
                                </div>
                                <div class="col-md-4">
                                    <select asp-for="CategoryId" asp-items="Model.CategoryList" class="dmx-choices">
                                        <option value="">Select Category</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>
                                <div class="col-md-4">
                                    <select asp-for="SupplierId" asp-items="Model.SupplierList" class="dmx-choices">
                                        <option value="">Select Supplier</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <select asp-for="UnitId" asp-items="Model.UnitList" class="dmx-choices">
                                        <option value="">Select Unit</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Description</label>
                                    <textarea asp-for="Description" class="form-control dmx-textarea" rows="2"
                                              placeholder="Optional notes about this product"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Pricing</h6>
                        </div>
                        <div class="card-body">
                            <div class="did-floating-label-content mb-3">
                                <input asp-for="CostPrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" id="costPrice" oninput="calcMargin()" />
                                <label class="did-floating-label">Cost Price (GHS) <span class="text-danger">*</span></label>
                                <span asp-validation-for="CostPrice" class="text-danger small"></span>
                            </div>
                            <div class="did-floating-label-content mb-3">
                                <input asp-for="SellingPrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" id="sellPrice" oninput="calcMargin()" />
                                <label class="did-floating-label">Selling Price (GHS) <span class="text-danger">*</span></label>
                                <span asp-validation-for="SellingPrice" class="text-danger small"></span>
                            </div>
                            <div class="did-floating-label-content mb-3">
                                <input asp-for="WholesalePrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" />
                                <label class="did-floating-label">Wholesale Price (GHS)</label>
                            </div>
                            <div class="p-2 rounded bg-light text-center small">
                                Margin: <strong id="marginDisplay">—</strong>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Stock Settings</h6>
                        </div>
                        <div class="card-body">
                            <div class="did-floating-label-content mb-3">
                                <input asp-for="CurrentStock" type="number" min="0" class="did-floating-input" />
                                <label class="did-floating-label">Opening Stock</label>
                            </div>
                            <div class="did-floating-label-content mb-3">
                                <input asp-for="ReorderLevel" type="number" min="0" class="did-floating-input" />
                                <label class="did-floating-label">Reorder Level</label>
                                <div class="form-text">Alert when stock drops to this level.</div>
                            </div>
                            <div class="form-check mb-3">
                                <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActive" />
                                <label class="form-check-label" for="isActive">Active product</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button  class="btn btn-outline-primary rounded-5">Save</button>
        </div>
    }
</dialog>

<script>
    function calcMargin() {
        const cost = parseFloat(document.getElementById('costPrice').value) || 0;
        const sell = parseFloat(document.getElementById('sellPrice').value) || 0;
        const el = document.getElementById('marginDisplay');
        if (sell > 0 && cost > 0) {
            const m = ((sell - cost) / sell * 100).toFixed(1);
            el.textContent = m + '%';
            el.style.color = m > 20 ? '#198754' : m > 10 ? '#fd7e14' : '#dc3545';
        } else {
            el.textContent = '—';
            el.style.color = '';
        }
    }

    @if (!ViewContext.ModelState.IsValid)
    {
            <text>
            document.addEventListener("DOMContentLoaded", function () {
                document.getElementById("AddProductDialog").showModal();
            });
            </text>
    }
</script>