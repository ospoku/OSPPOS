@model OSPPOS.ViewModels.AddStockBatchVM

<dialog id="AddStockBatchDialog" class="col-md-8 border-0 rounded p-0">
    <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-truck"></i> Receive Stock (GRN)
        </h6>
        <button type="button" class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddStockBatchDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddStockBatch", "Stock", FormMethod.Post, new { id = "addStockBatchForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <!-- Batch Header -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0 fw-semibold">Delivery Details</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <select asp-for="SupplierId" asp-items="Model.SupplierList" class="dmx-choices">
                                <option value="">Select Supplier</option>
                            </select>
                            <span asp-validation-for="SupplierId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="did-floating-label-content">
                                <input asp-for="ReceivedDate" type="date" class="did-floating-input" />
                                <label class="did-floating-label">Received Date</label>
                                <span asp-validation-for="ReceivedDate" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="did-floating-label-content">
                                <input asp-for="SupplierInvoiceRef" type="text" class="did-floating-input" placeholder=" " />
                                <label class="did-floating-label">Supplier Invoice Ref</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="did-floating-label-content">
                                <input asp-for="Notes" type="text" class="did-floating-input" placeholder=" " />
                                <label class="did-floating-label">Notes</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Line Items -->
            <div class="card shadow-sm">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold">Products Received</h6>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addLine()">
                        <i class="fas fa-plus"></i> Add Line
                    </button>
                </div>
                <div class="card-body p-3">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Unit Cost (GHS)</th>
                                <th>Total</th>
                                <th>Expiry</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="lineItems">
                            @for (int i = 0; i < Model.Items.Count; i++)
                            {
                                <tr>
                                    <td>
                                        <select name="Items[@i].ProductId" class="dmx-choices form-select form-select-sm">
                                            <option value="">Select Product</option>
                                            @foreach (var item in Model.ProductList)
                                            {
                                                 <option value="@item.Value @(item.Value == Model.Items[i].ProductId.ToString() ? "selected" : "")">
                                                    @item.Text 
                                                </option> 
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input name="Items[@i].Quantity" type="number" min="1"
                                               value="@Model.Items[i].Quantity"
                                               class="form-control form-control-sm" oninput="calcTotal(this)" />
                                    </td>
                                    <td>
                                        <input name="Items[@i].UnitCost" type="number" step="0.01" min="0"
                                               value="@Model.Items[i].UnitCost"
                                               class="form-control form-control-sm" oninput="calcTotal(this)" />
                                    </td>
                                    <td>
                                        <span class="line-total fw-semibold">0.00</span>
                                    </td>
                                    <td>
                                        <input name="Items[@i].ExpiryDate" type="date"
                                               value="@Model.Items[i].ExpiryDate?.ToString("yyyy-MM-dd")"
                                               class="form-control form-control-sm" />
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="removeLine(this)">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="3" class="text-end fw-semibold">Batch Total:</td>
                                <td><span id="batchTotal" class="fw-bold">0.00</span></td>
                                <td colspan="2"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button type="submit" class="btn btn-primary">Save GRN</button>
        </div>
    }
</dialog>

<script>
    let lineIndex = @Model.Items.Count;

    const productOptions = `<option value="">Select Product</option>
        @foreach (var item in Model.ProductList)
        {
            <text><option value="@item.Value">@item.Text</option></text>
        }`;

    function addLine() {
        const row = `
            <tr>
                <td><select name="Items[${lineIndex}].ProductId" class="dmx-choices form-select form-select-sm">${productOptions}</select></td>
                <td><input name="Items[${lineIndex}].Quantity" type="number" min="1" value="0" class="form-control form-control-sm" oninput="calcTotal(this)" /></td>
                <td><input name="Items[${lineIndex}].UnitCost" type="number" step="0.01" min="0" value="0.00" class="form-control form-control-sm" oninput="calcTotal(this)" /></td>
                <td><span class="line-total fw-semibold">0.00</span></td>
                <td><input name="Items[${lineIndex}].ExpiryDate" type="date" class="form-control form-control-sm" /></td>
                <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeLine(this)"><i class="fas fa-times"></i></button></td>
            </tr>`;
        document.getElementById('lineItems').insertAdjacentHTML('beforeend', row);
        lineIndex++;
        updateBatchTotal();
    }

    function removeLine(btn) {
        btn.closest('tr').remove();
        updateBatchTotal();
    }

    function calcTotal(input) {
        const row = input.closest('tr');
        const qty = parseFloat(row.querySelector('input[name*="Quantity"]').value) || 0;
        const cost = parseFloat(row.querySelector('input[name*="UnitCost"]').value) || 0;
        row.querySelector('.line-total').textContent = (qty * cost).toFixed(2);
        updateBatchTotal();
    }

    function updateBatchTotal() {
        const totals = [...document.querySelectorAll('.line-total')]
            .reduce((sum, el) => sum + parseFloat(el.textContent || 0), 0);
        document.getElementById('batchTotal').textContent = totals.toFixed(2);
    }

</script>
<dialog id="AddStockBatchDialog" class="col-md-8 border-0 rounded p-0">
    <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-truck"></i> Receive Stock (GRN)
        </h6>
        <button type="button" class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddStockBatchDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddStockBatch", "Stock", FormMethod.Post, new { id = "addStockBatchForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-body">

            <!-- Validation errors -->
            <div id="grn-errors" class="alert alert-danger small py-2" style="display:none">
                <ul id="grn-error-list" class="mb-0"></ul>
            </div>

            <!-- Delivery Details -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0 fw-semibold">Delivery details</h6>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small">Supplier <span class="text-danger">*</span></label>
                            <select id="grnSupplier" asp-for="SupplierId" asp-items="Model.SupplierList" class="dmx-choices form-select form-select-sm">
                                <option value="">Select supplier</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Received date <span class="text-danger">*</span></label>
                            <input asp-for="ReceivedDate" type="date" class="form-control form-control-sm" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Supplier invoice ref</label>
                            <input asp-for="SupplierInvoiceRef" type="text" class="form-control form-control-sm" placeholder="e.g. INV-00123" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Notes</label>
                            <input asp-for="Notes" type="text" class="form-control form-control-sm" placeholder="Optional notes" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Line Items -->
            <div class="card shadow-sm">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-semibold">Products received</h6>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addLine()">
                        <i class="fas fa-plus me-1"></i> Add line
                    </button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0" style="table-layout:fixed;min-width:600px">
                        <colgroup>
                            <col style="width:35%">
                            <col style="width:10%">
                            <col style="width:15%">
                            <col style="width:12%">
                            <col style="width:16%">
                            <col style="width:6%">
                            <col style="width:6%">
                        </colgroup>
                        <thead class="table-light">
                            <tr>
                                <th class="small">Product</th>
                                <th class="small">Qty</th>
                                <th class="small">Unit cost (GHS)</th>
                                <th class="small text-end">Total</th>
                                <th class="small">Expiry date</th>
                                <th class="small text-center">Active</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="lineItems">
                            @if (!Model.Items.Any())
                            {
                                <tr id="emptyRow">
                                    <td colspan="7" class="text-center text-muted py-4 small">
                                        <i class="fas fa-box-open d-block mb-1" style="font-size:1.4rem"></i>
                                        No products added yet — click "Add line" to start
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <select name="Items[@i].ProductId" class="form-select form-select-sm dmx-choices">
                                                <option value="">Select product</option>
                                                @foreach (var item in Model.ProductList)
                                                {
                                                    <option value="@item.Value"
                                                            @(item.Value == Model.Items[i].ProductId.ToString() ? "selected" : "")>
                                                        @item.Text
                                                    </option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input name="Items[@i].Quantity" type="number" min="1"
                                                   value="@Model.Items[i].Quantity"
                                                   class="form-control form-control-sm text-end"
                                                   oninput="calcTotal(this)" />
                                        </td>
                                        <td>
                                            <input name="Items[@i].UnitCost" type="number" step="0.01" min="0"
                                                   value="@Model.Items[i].UnitCost"
                                                   class="form-control form-control-sm text-end"
                                                   oninput="calcTotal(this)" />
                                        </td>
                                        <td class="text-end fw-semibold">
                                            <span class="line-total">@((Model.Items[i].Quantity * Model.Items[i].UnitCost).ToString("F2"))</span>
                                        </td>
                                        <td>
                                            <input name="Items[@i].ExpiryDate" type="date"
                                                   value="@Model.Items[i].ExpiryDate?.ToString("yyyy-MM-dd")"
                                                   class="form-control form-control-sm" />
                                        </td>
                                        <td class="text-center">
                                            <input name="Items[@i].IsActive" type="checkbox" class="form-check-input" checked />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger px-2"
                                                    onclick="removeLine(this)" aria-label="Remove line">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="3" class="text-end small fw-semibold">Batch total</td>
                                <td class="text-end">
                                    <span id="batchTotal" class="fw-bold">GHS 0.00</span>
                                </td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button type="button" class="btn btn-secondary btn-sm"
                    onclick="document.getElementById('AddStockBatchDialog').close()">
                Cancel
            </button>
            <button type="button" class="btn btn-primary btn-sm" onclick="validateAndSaveGRN()">
                <i class="fas fa-save me-1"></i> Save GRN
            </button>
        </div>
    }
</dialog>

<script>
    let grnLineIndex = @Model.Items.Count;

    const grnProductOptions = [
        '<option value="">Select product</option>',
        @foreach (var item in Model.ProductList)
        {
            <text>'<option value="@item.Value">@Html.Raw(item.Text)</option>',</text>
        }
    ].join('');

    function addLine() {
        const empty = document.getElementById('emptyRow');
        if (empty) empty.remove();

        const row = document.createElement('tr');
        row.innerHTML = `
            <td>
                <select name="Items[${grnLineIndex}].ProductId" class="form-select form-select-sm dmx-choices">
                    ${grnProductOptions}
                </select>
            </td>
            <td>
                <input name="Items[${grnLineIndex}].Quantity" type="number" min="1" value="1"
                       class="form-control form-control-sm text-end" oninput="calcTotal(this)" />
            </td>
            <td>
                <input name="Items[${grnLineIndex}].UnitCost" type="number" step="0.01" min="0" value="0.00"
                       class="form-control form-control-sm text-end" oninput="calcTotal(this)" />
            </td>
            <td class="text-end fw-semibold">
                <span class="line-total">0.00</span>
            </td>
            <td>
                <input name="Items[${grnLineIndex}].ExpiryDate" type="date" class="form-control form-control-sm" />
            </td>
            <td class="text-center">
                <input name="Items[${grnLineIndex}].IsActive" type="checkbox" class="form-check-input" checked />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger px-2"
                        onclick="removeLine(this)" aria-label="Remove line">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </td>`;

        document.getElementById('lineItems').appendChild(row);
        grnLineIndex++;
        updateBatchTotal();
    }

    function removeLine(btn) {
        btn.closest('tr').remove();

        const tbody = document.getElementById('lineItems');
        const remaining = tbody.querySelectorAll('tr:not(#emptyRow)');

        if (!remaining.length) {
            const tr = document.createElement('tr');
            tr.id = 'emptyRow';
            tr.innerHTML = `
                <td colspan="7" class="text-center text-muted py-4 small">
                    <i class="fas fa-box-open d-block mb-1" style="font-size:1.4rem"></i>
                    No products added yet — click "Add line" to start
                </td>`;
            tbody.appendChild(tr);
        }

        updateBatchTotal();
    }

    function calcTotal(input) {
        const row = input.closest('tr');
        const qty = parseFloat(row.querySelector('input[name*="Quantity"]').value) || 0;
        const cost = parseFloat(row.querySelector('input[name*="UnitCost"]').value) || 0;
        row.querySelector('.line-total').textContent = (qty * cost).toFixed(2);
        updateBatchTotal();
    }

    function updateBatchTotal() {
        const total = [...document.querySelectorAll('.line-total')]
            .reduce((sum, el) => sum + parseFloat(el.textContent || 0), 0);
        document.getElementById('batchTotal').textContent = 'GHS ' + total.toFixed(2);
    }

    function validateAndSaveGRN() {
        const errors = [];

        const supplier = document.getElementById('grnSupplier').value;
        if (!supplier) errors.push('Please select a supplier.');

        const rows = [...document.querySelectorAll('#lineItems tr')].filter(r => r.id !== 'emptyRow');
        if (!rows.length) errors.push('Please add at least one product.');

        rows.forEach((row, i) => {
            const product = row.querySelector('select').value;
            const qty = parseFloat(row.querySelector('input[name*="Quantity"]').value) || 0;
            const cost = parseFloat(row.querySelector('input[name*="UnitCost"]').value) || 0;

            if (!product) errors.push(`Line ${i + 1}: please select a product.`);
            if (qty < 1) errors.push(`Line ${i + 1}: quantity must be at least 1.`);
            if (cost <= 0) errors.push(`Line ${i + 1}: unit cost must be greater than 0.`);
        });

        if (errors.length > 0) {
            const list = document.getElementById('grn-error-list');
            list.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
            document.getElementById('grn-errors').style.display = 'block';
            return;
        }

        document.getElementById('grn-errors').style.display = 'none';
        document.getElementById('addStockBatchForm').submit();
    }

    // Recalculate totals on load for repopulated lines
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('#lineItems tr:not(#emptyRow)').forEach(row => {
            const qty = parseFloat(row.querySelector('input[name*="Quantity"]')?.value) || 0;
            const cost = parseFloat(row.querySelector('input[name*="UnitCost"]')?.value) || 0;
            const total = row.querySelector('.line-total');
            if (total) total.textContent = (qty * cost).toFixed(2);
        });
        updateBatchTotal();
    });
</script>
