                <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('AddInvoiceDialog').close()">
                    Cancel
                </button>
                <button id="confirmBtn" class="btn btn-success" disabled>
                    <i class="fas fa-check-circle me-1"></i>
                    Confirm sale — <span id="btnTotal">GHS 0.00</span>
                </button>
            </div>
          
        }

   
</dialog>




