            box-shadow: 0 0 0 3px rgba(45, 138, 78, 0.15);
        }

        /* ── Footer ──────────────────────────────────────────────────── */
        .sale-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 24px;
