@model OSPPOS.ViewModels.AddStockBatchVM




<dialog id="AddStockBatchDialog" class="border-0 rounded p-0" style="max-width: 950px; width: 100%;">
    <div class="modal-header-custom">
        <h6>
            <i class="fas fa-fw fa-truck"></i> Receive Stock (GRN)
        </h6>
        <button type="button" class="btn-close-custom" onclick="document.getElementById('AddStockBatchDialog').close()">
            <i class="fas fa-times"></i> Close
        </button>
    </div>

    @using (Html.BeginForm("AddStockBatch", "Stock", FormMethod.Post, new { id = "addStockBatchForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-body-custom">

            <!-- Validation errors -->
            <div id="grn-errors" class="alert alert-danger small py-2 alert-dark" style="display:none">
                <ul id="grn-error-list" class="mb-0"></ul>
            </div>

            <!-- Delivery Details -->
            <div class="card-custom shadow-sm mb-3">
                <div class="card-header-custom">
                    <h6><i class="fas fa-truck"></i> Delivery Details</h6>
                </div>
                <div class="card-body-custom">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label-dark">Supplier <span class="text-danger-dark">*</span></label>
                            <select id="grnSupplier" asp-for="SupplierId" asp-items="Model.SupplierList" 
                                    class="choices-select form-select-dark" 
                                    data-placeholder="Select supplier">
                                <option value="">Select supplier</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-dark">Received date <span class="text-danger-dark">*</span></label>
                            <input asp-for="ReceivedDate" type="date" class="form-control form-control-dark" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-dark">Supplier invoice ref</label>
                            <input asp-for="SupplierInvoiceRef" type="text" class="form-control form-control-dark" placeholder="e.g. INV-00123" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-dark">Notes</label>
                            <input asp-for="Notes" type="text" class="form-control form-control-dark" placeholder="Optional notes" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Line Items -->
            <div class="card-custom shadow-sm">
                <div class="card-header-custom d-flex justify-content-between align-items-center">
                    <h6><i class="fas fa-boxes"></i> Products Received</h6>
                    <button type="button" class="btn btn-sm btn-outline-primary-custom" onclick="addLine()">
                        <i class="fas fa-plus me-1"></i> Add line
                    </button>
                </div>
                <div class="table-responsive p-3">
                    <table class="table table-sm table-hover align-middle mb-0" style="table-layout:fixed;min-width:600px;color: #e4e6eb;">
                        <colgroup>
                            <col style="width:35%">
                            <col style="width:10%">
                            <col style="width:15%">
                            <col style="width:12%">
                            <col style="width:16%">
                            <col style="width:6%">
                            <col style="width:6%">
                        </colgroup>
                        <thead style="background: #1a1d23; color: #8c929a;">
                            <tr>
                                <th class="small">Product</th>
                                <th class="small">Qty</th>
                                <th class="small">Unit cost (GHS)</th>
                                <th class="small text-end">Total</th>
                                <th class="small">Expiry date</th>
                                <th class="small text-center">Active</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="lineItems">
                            @if (!Model.Items.Any())
                            {
                                <tr id="emptyRow">
                                    <td colspan="7" class="text-center text-muted py-4 small">
                                        <i class="fas fa-box-open d-block mb-1" style="font-size:1.4rem"></i>
                                        No products added yet — click "Add line" to start
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <select name="Items[@i].ProductId" class="form-select form-select-dark choices-select">
                                                <option value="">Select product</option>
                                                @foreach (var item in Model.ProductList)
                                                {
                                                    <option value=" Model.Items[i].ProductId.ToString() ? "selected" >
                                                        @item.Text
                                                    </option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <input name="Items[@i].Quantity" type="number" min="1"
                                                   value="@Model.Items[i].Quantity"
                                                   class="form-control form-control-dark text-end"
                                                   oninput="calcTotal(this)" />
                                        </td>
                                        <td>
                                            <input name="Items[@i].UnitCost" type="number" step="0.01" min="0"
                                                   value="@Model.Items[i].UnitCost"
                                                   class="form-control form-control-dark text-end"
                                                   oninput="calcTotal(this)" />
                                        </td>
                                        <td class="text-end fw-semibold">
                                            <span class="line-total">@((Model.Items[i].Quantity * Model.Items[i].UnitCost).ToString("F2"))</span>
                                        </td>
                                        <td>
                                            <input name="Items[@i].ExpiryDate" type="date"
                                                   value="@Model.Items[i].ExpiryDate?.ToString("yyyy-MM-dd")"
                                                   class="form-control form-control-dark" />
                                        </td>
                                        <td class="text-center">
                                            <input name="Items[@i].IsActive" type="checkbox" 
                                                   class="form-check-input form-check-input-dark" checked />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-sm btn-outline-danger-custom px-2"
                                                    onclick="removeLine(this)" aria-label="Remove line">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr style="background: #1a1d23;">
                                <td colspan="3" class="text-end small fw-semibold" style="color: #8c929a;">Batch total</td>
                                <td class="text-end">
                                    <span id="batchTotal" class="fw-bold" style="color: #667eea;">GHS 0.00</span>
                                </td>
                                <td colspan="3"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="modal-footer-custom">
            <button type="button" class="btn btn-secondary-custom" onclick="document.getElementById('AddStockBatchDialog').close()">
                Cancel
            </button>
            <button type="button" class="btn-save-custom" onclick="validateAndSaveGRN()">
                <i class="fas fa-save me-1"></i> Save GRN
            </button>
        </div>
    }
</dialog>

