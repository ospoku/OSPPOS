 @model OSPPOS.ViewModels.AddCustomerVM

<dialog id="AddCustomerDialog">

        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-user"></i> Add Customer
        </h6>
        <button type="button" aria-label="Close"
                class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddCustomerDialog').close()">
            Close
        </button>
   
    <div class="modal-body">
    @using (Html.BeginForm("AddCustomer", "Customer", FormMethod.Post, new { id = "addCustomerForm" }))
    {
        @Html.AntiForgeryToken()

        <div>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <!-- Name -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-user"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Name" type="text" class="did-floating-input" placeholder=" " required />
                    <label class="did-floating-label">Customer Name <span class="text-danger">*</span></label>
                </div>
            </div>
            <span asp-validation-for="Name" class="text-danger small"></span>

            <!-- Email -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-envelope"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Email" type="email" class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Email</label>
                </div>
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>

            <!-- Phone -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-phone"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Phone" type="tel" class="did-floating-input" placeholder=" " required />
                    <label class="did-floating-label">Phone</label>
                </div>
            </div>

            <!-- Address -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-map-marker-alt"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Address" class="did-floating-input" type="text"
                               placeholder=" ">
                    <label class="did-floating-label">Address</label>
                </div>
            </div>

            <!-- Tax Number -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-receipt"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="TaxNumber" type="text" class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Tax Number</label>
                </div>
            </div>

            <!-- Credit Settings -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0 fw-semibold">Credit Settings</h6>
                </div>
                <div class="card-body">
                    <div class="form-check mb-3">
                        <input asp-for="AllowCredit" type="checkbox" class="form-check-input"
                               id="allowCredit" onchange="toggleCreditLimit(this)" />
                        <label class="form-check-label" for="allowCredit">Allow credit purchases</label>
                    </div>
                    <div id="creditLimitWrapper" class="did-floating-label-content"
                         style="display: @(Model.AllowCredit ? "block" : "none")">
                        <input asp-for="CreditLimit" type="number" step="0.01" min="0"
                               class="did-floating-input" placeholder=" " />
                        <label class="did-floating-label">Credit Limit (GHS)</label>
                        <span asp-validation-for="CreditLimit" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Active -->
            <div class="form-check">
                <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActive" />
                <label class="form-check-label" for="isActive">Active customer</label>
            </div>
        </div>

        <div>
            <button type="submit" class="btn btn-primary btn-block">Save</button>
        </div>
    }
   
    </div>
</dialog>

<script>
    function toggleCreditLimit(checkbox) {
        document.getElementById('creditLimitWrapper').style.display =
            checkbox.checked ? 'block' : 'none';
    }

 
</script> 

               