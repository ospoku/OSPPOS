<script>
    let grnLineIndex = @Model.Items.Count();

    const grnProductOptions = [
        '<option value="">Select product</option>',
        @foreach (var item in Model.ProductList)
        {
            <text>'<option value="@item.Value">@Html.Raw(item.Text)</option>',</text>
        }
    ].join('');

    function addLine() {
        const empty = document.getElementById('emptyRow');
        if (empty) empty.remove();

        const row = document.createElement('tr');
        row.innerHTML = `
            <td>
                <select name="Items[${grnLineIndex}].ProductId" class="form-select form-select-dark choices-select">
                    ${grnProductOptions}
                </select>
            </td>
            <td>
                <input name="Items[${grnLineIndex}].Quantity" type="number" min="1" value="1"
                       class="form-control form-control-dark text-end" oninput="calcTotal(this)" />
            </td>
            <td>
                <input name="Items[${grnLineIndex}].UnitCost" type="number" step="0.01" min="0" value="0.00"
                       class="form-control form-control-dark text-end" oninput="calcTotal(this)" />
            </td>
            <td class="text-end fw-semibold">
                <span class="line-total">0.00</span>
            </td>
            <td>
                <input name="Items[${grnLineIndex}].ExpiryDate" type="date" class="form-control form-control-dark" />
            </td>
            <td class="text-center">
                <input name="Items[${grnLineIndex}].IsActive" type="checkbox" class="form-check-input form-check-input-dark" checked />
            </td>
            <td class="text-center">
                <button type="button" class="btn btn-sm btn-outline-danger-custom px-2"
                        onclick="removeLine(this)" aria-label="Remove line">
                    <i class="fas fa-trash-alt"></i>
                </button>
            </td>`;

        document.getElementById('lineItems').appendChild(row);
        grnLineIndex++;

        // Initialize Choices.js for the new select
        initializeChoices(row.querySelector('.choices-select'));

        updateBatchTotal();
    }

    function removeLine(btn) {
        btn.closest('tr').remove();

        const tbody = document.getElementById('lineItems');
        const remaining = tbody.querySelectorAll('tr:not(#emptyRow)');

        if (!remaining.length) {
            const tr = document.createElement('tr');
            tr.id = 'emptyRow';
            tr.innerHTML = `
                <td colspan="7" class="text-center text-muted py-4 small">
                    <i class="fas fa-box-open d-block mb-1" style="font-size:1.4rem"></i>
                    No products added yet — click "Add line" to start
                </td>`;
            tbody.appendChild(tr);
        }

        updateBatchTotal();
    }

    function calcTotal(input) {
        const row = input.closest('tr');
        const qty = parseFloat(row.querySelector('input[name*="Quantity"]').value) || 0;
        const cost = parseFloat(row.querySelector('input[name*="UnitCost"]').value) || 0;
        row.querySelector('.line-total').textContent = (qty * cost).toFixed(2);
        updateBatchTotal();
    }

    function updateBatchTotal() {
        const total = [...document.querySelectorAll('.line-total')]
            .reduce((sum, el) => sum + parseFloat(el.textContent || 0), 0);
        document.getElementById('batchTotal').textContent = 'GHS ' + total.toFixed(2);
    }

    function validateAndSaveGRN() {
        const errors = [];

        const supplier = document.getElementById('grnSupplier').value;
        if (!supplier) errors.push('Please select a supplier.');

        const rows = [...document.querySelectorAll('#lineItems tr')].filter(r => r.id !== 'emptyRow');
        if (!rows.length) errors.push('Please add at least one product.');

        rows.forEach((row, i) => {
            const product = row.querySelector('select').value;
            const qty = parseFloat(row.querySelector('input[name*="Quantity"]').value) || 0;
            const cost = parseFloat(row.querySelector('input[name*="UnitCost"]').value) || 0;

            if (!product) errors.push(`Line ${i + 1}: please select a product.`);
            if (qty < 1) errors.push(`Line ${i + 1}: quantity must be at least 1.`);
            if (cost <= 0) errors.push(`Line ${i + 1}: unit cost must be greater than 0.`);
        });

        if (errors.length > 0) {
            const list = document.getElementById('grn-error-list');
            list.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
            document.getElementById('grn-errors').style.display = 'block';
            return;
        }

        document.getElementById('grn-errors').style.display = 'none';
        document.getElementById('addStockBatchForm').submit();
    }

    // Initialize Choices.js for all selects
    function initializeChoices(element) {
        if (typeof Choices !== 'undefined') {
            new Choices(element, {
                searchEnabled: true,
                searchPlaceholderValue: 'Search...',
                placeholder: true,
                placeholderValue: element.dataset.placeholder || 'Select option...',
                shouldSort: false,
                itemSelectText: '',
                noResultsText: 'No options found',
                noChoicesText: 'No options available',
                classNames: {
                    containerOuter: 'choices choices-dark-grn',
                    containerInner: 'choices__inner choices__inner-dark',
                    input: 'choices__input choices__input-dark',
                    inputCloned: 'choices__input--cloned',
                    list: 'choices__list',
                    listItems: 'choices__list--multiple',
                    listSingle: 'choices__list--single',
                    listDropdown: 'choices__list--dropdown',
                    item: 'choices__item',
                    itemSelectable: 'choices__item--selectable',
                    itemDisabled: 'choices__item--disabled',
                    itemChoice: 'choices__item--choice',
                    placeholder: 'choices__placeholder',
                    group: 'choices__group',
                    groupHeading: 'choices__heading',
                    button: 'choices__button',
                    activeState: 'is-active',
                    focusState: 'is-focused',
                    openState: 'is-open',
                    disabledState: 'is-disabled',
                    highlightedState: 'is-highlighted',
                    selectedState: 'is-selected',
                    flippedState: 'is-flipped',
                    loadingState: 'is-loading',
                    noResults: 'has-no-results',
                    noChoices: 'has-no-choices'
                }
            });
        }
    }

    // Initialize on DOM load
    document.addEventListener('DOMContentLoaded', function () {
        // Initialize all Choices selects
        document.querySelectorAll('.choices-select').forEach(select => {
            initializeChoices(select);
        });

        // Recalculate totals on load for repopulated lines
        document.querySelectorAll('#lineItems tr:not(#emptyRow)').forEach(row => {
            const qty = parseFloat(row.querySelector('input[name*="Quantity"]')?.value) || 0;
            const cost = parseFloat(row.querySelector('input[name*="UnitCost"]')?.value) || 0;
            const total = row.querySelector('.line-total');
            if (total) total.textContent = (qty * cost).toFixed(2);
        });
        updateBatchTotal();
    });
      // Store Choices instances for cleanup
        let choicesInstances = [];

        function initializeChoices(selectElement) {
            if (!selectElement) return;

            // If already a Choices instance, destroy it first
            if (selectElement._choicesInstance) {
                selectElement._choicesInstance.destroy();
            }

            const choices = new Choices(selectElement, {
                searchEnabled: true,
                searchPlaceholderValue: 'Search products...',
                placeholder: true,
                placeholderValue: selectElement.dataset.placeholder || 'Select option...',
                shouldSort: false,
                itemSelectText: '',
                noResultsText: 'No products found',
                noChoicesText: 'No products available',
                searchResultLimit: 20,
                position: 'bottom',
                classNames: {
                    containerOuter: 'choices',
                    containerInner: 'choices__inner',
                    input: 'choices__input',
                    inputCloned: 'choices__input--cloned',
                    list: 'choices__list',
                    listItems: 'choices__list--multiple',
                    listSingle: 'choices__list--single',
                    listDropdown: 'choices__list--dropdown',
                    item: 'choices__item',
                    itemSelectable: 'choices__item--selectable',
                    itemDisabled: 'choices__item--disabled',
                    itemChoice: 'choices__item--choice',
                    placeholder: 'choices__placeholder',
                    group: 'choices__group',
                    groupHeading: 'choices__heading',
                    button: 'choices__button',
                    activeState: 'is-active',
                    focusState: 'is-focused',
                    openState: 'is-open',
                    disabledState: 'is-disabled',
                    highlightedState: 'is-highlighted',
                    selectedState: 'is-selected',
                    flippedState: 'is-flipped',
                    loadingState: 'is-loading',
                    noResults: 'has-no-results',
                    noChoices: 'has-no-choices'
                }
            });

            // Store reference on the element
            selectElement._choicesInstance = choices;
            choicesInstances.push(choices);

            return choices;
        }

        let grnLineIndex = 2; // Start after sample rows

        const grnProductOptions = [
            '<option value="">Select product</option>',
            '<option value="1">Premium Coffee Beans</option>',
            '<option value="2">Organic Green Tea</option>',
            '<option value="3">Dark Chocolate Bar</option>',
            '<option value="4">Almond Milk</option>',
            '<option value="5">Vanilla Extract</option>',
            '<option value="6">Coconut Oil</option>',
            '<option value="7">Honey</option>',
            '<option value="8">Cinnamon Sticks</option>',
        ].join('');

        function addLine() {
            const empty = document.getElementById('emptyRow');
            if (empty) empty.remove();

            const row = document.createElement('tr');
            row.innerHTML = `
                <td>
                    <select class="form-select form-select-dark choices-select" data-placeholder="Search products...">
                        ${grnProductOptions}
                    </select>
                </td>
                <td>
                    <input type="number" min="1" value="1" class="form-control form-control-dark text-end" oninput="calcTotal(this)" />
                </td>
                <td>
                    <input type="number" step="0.01" min="0" value="0.00" class="form-control form-control-dark text-end" oninput="calcTotal(this)" />
                </td>
                <td class="text-end fw-semibold">
                    <span class="line-total">0.00</span>
                </td>
                <td>
                    <input type="date" class="form-control form-control-dark" />
                </td>
                <td class="text-center">
                    <input type="checkbox" class="form-check-input form-check-input-dark" checked />
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger-custom px-2" onclick="removeLine(this)">
                        <i class="fas fa-trash-alt"></i>
                    </button>
                </td>`;

            document.getElementById('lineItems').appendChild(row);
            grnLineIndex++;

            // Initialize Choices for the new select
            const newSelect = row.querySelector('.choices-select');
            if (typeof Choices !== 'undefined') {
                initializeChoices(newSelect);
            }

            updateBatchTotal();
        }

        function removeLine(btn) {
            const row = btn.closest('tr');
            const select = row.querySelector('.choices-select');

            // Clean up Choices instance
            if (select && select._choicesInstance) {
                select._choicesInstance.destroy();
                delete select._choicesInstance;
            }

            row.remove();

            const tbody = document.getElementById('lineItems');
            const remaining = tbody.querySelectorAll('tr');

            if (!remaining.length) {
                const tr = document.createElement('tr');
                tr.id = 'emptyRow';
                tr.innerHTML = `
                    <td colspan="7" class="text-center text-muted py-4 small">
                        <i class="fas fa-box-open d-block mb-1" style="font-size:1.4rem"></i>
                        No products added yet — click "Add line" to start
                    </td>`;
                tbody.appendChild(tr);
            }

            updateBatchTotal();
        }

        function calcTotal(input) {
            const row = input.closest('tr');
            const qty = parseFloat(row.querySelector('input[type="number"]').value) || 0;
            const cost = parseFloat(row.querySelectorAll('input[type="number"]')[1].value) || 0;
            row.querySelector('.line-total').textContent = (qty * cost).toFixed(2);
            updateBatchTotal();
        }

        function updateBatchTotal() {
            const totals = document.querySelectorAll('.line-total');
            let sum = 0;
            totals.forEach(el => {
                sum += parseFloat(el.textContent || 0);
            });
            document.getElementById('batchTotal').textContent = 'GHS ' + sum.toFixed(2);
        }

        function validateAndSaveGRN() {
            const errors = [];

            const supplier = document.getElementById('grnSupplier');
            const supplierValue = supplier ? supplier.value : '';
            if (!supplierValue) errors.push('Please select a supplier.');

            const rows = document.querySelectorAll('#lineItems tr');
            const visibleRows = Array.from(rows).filter(r => r.id !== 'emptyRow');

            if (!visibleRows.length) errors.push('Please add at least one product.');

            visibleRows.forEach((row, i) => {
                const select = row.querySelector('.choices-select');
                const product = select ? select.value : '';
                const qtyInput = row.querySelector('input[type="number"]');
                const costInput = row.querySelectorAll('input[type="number"]')[1];
                const qty = qtyInput ? parseFloat(qtyInput.value) || 0 : 0;
                const cost = costInput ? parseFloat(costInput.value) || 0 : 0;

                if (!product) errors.push(`Line ${i + 1}: please select a product.`);
                if (qty < 1) errors.push(`Line ${i + 1}: quantity must be at least 1.`);
                if (cost <= 0) errors.push(`Line ${i + 1}: unit cost must be greater than 0.`);
            });

            if (errors.length > 0) {
                const list = document.getElementById('grn-error-list');
                list.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
                document.getElementById('grn-errors').style.display = 'block';
                return;
            }

            document.getElementById('grn-errors').style.display = 'none';
            alert('✅ GRN saved successfully! (Demo)');
            document.getElementById('AddStockBatchDialog').close();
        }

        // Initialize Choices.js on DOM load
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize all select elements with class 'choices-select'
            document.querySelectorAll('.choices-select').forEach(select => {
                initializeChoices(select);
            });

            // Recalculate totals
            updateBatchTotal();

            // Handle dialog open/close for cleanup
            const dialog = document.getElementById('AddStockBatchDialog');
            dialog.addEventListener('close', function() {
                // Destroy all Choices instances when dialog closes
                choicesInstances.forEach(instance => {
                    try { instance.destroy(); } catch (e) {}
                });
                choicesInstances = [];
            });
        });

        // Reinitialize Choices when dialog opens (for dynamic content)
        document.getElementById('AddStockBatchDialog').addEventListener('click', function(e) {
            // This ensures any dynamically added selects get initialized
            setTimeout(function() {
                document.querySelectorAll('.choices-select:not(.choices-initialized)').forEach(select => {
                    initializeChoices(select);
                    select.classList.add('choices-initialized');
                });
            }, 100);
        });
</script>
