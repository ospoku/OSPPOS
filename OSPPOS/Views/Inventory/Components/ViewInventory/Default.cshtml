@{ ViewData["Title"] = "Stock Levels"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="fas fa-boxes me-2 text-primary"></i>Stock levels</h4>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-sm btn-outline-secondary no-print">
            <i class="fas fa-print me-1"></i>Print
        </button>
        <a asp-action="DownloadStock" class="btn btn-sm btn-outline-success no-print">
            <i class="fas fa-file-excel me-1"></i>Export
        </a>
        <a asp-controller="Stock" asp-action="Create" class="btn btn-sm btn-primary no-print">
            <i class="fas fa-truck-loading me-1"></i>New GRN
        </a>
    </div>
</div>

@{
    var outOfStock   = Model.Products.Count(p => p.CurrentStock == 0);
    var lowStock = Model.Products.Count(p => p.CurrentStock > 0 && p.IsLowStock);
    var totalRetail = Model.Products.Sum(p => p.CurrentStock * p.SellingPrice);
    var totalCost = Model.Products.Sum(p => p.CurrentStock * p.CostPrice);
    var maxStock = Model.Products.Any() ? (double)Model.Products.Max(p => p.CurrentStock) : 1;
}

<!-- Summary cards -->
<div class="row g-2 mb-3">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold">@Model.Products.Count</div>
            <div class="small text-muted">Total products</div>
            <div class="x-small text-muted">
           @*      @Model.Products.Count(p => p.Category?.Type == "Soft") soft
                &middot; @Model.Products.Count(p => p.Category?.Type == "Hard") hard *@
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-danger">@outOfStock</div>
            <div class="small text-muted">Out of stock</div>
            <div class="x-small text-muted">needs immediate restock</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-4 fw-bold text-warning">@lowStock</div>
            <div class="small text-muted">Low stock</div>
            <div class="x-small text-muted">below reorder level</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="fs-5 fw-bold text-success">GHS @totalRetail.ToString("N2")</div>
            <div class="small text-muted">Stock value (retail)</div>
            <div class="x-small text-muted">cost: GHS @totalCost.ToString("N2")</div>
        </div>
    </div>
</div>

