@model OSPPOS.ViewModels.EditProductVM

<dialog id="EditProductDialog" class="col-md-8 border-0 rounded p-0">
    <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-edit"></i> Edit Product
        </h6>
        <button type="button" class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('EditProductDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("EditProduct", "Product", FormMethod.Post, new { id = "editProductForm" }))
    {
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />

        <div class="modal-body">

            <!-- Validation errors -->
            <div id="editProductErrors" class="alert alert-danger small py-2" style="display:none">
                <ul id="editProductErrorList" class="mb-0"></ul>
            </div>

            <div class="row g-3">

                <!-- Left: Product Details -->
                <div class="col-lg-8">
                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Product details</h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">

                                <div class="did-floating-label-content col-md-8">
                                    <input asp-for="Name" type="text" class="did-floating-input" placeholder=" " />
                                    <label class="did-floating-label">Product name <span class="text-danger">*</span></label>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>

                                <div class="did-floating-label-content col-md-4">
                                    <input asp-for="SKU" type="text" class="did-floating-input" placeholder=" " />
                                    <label class="did-floating-label">SKU / Code</label>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small">Category <span class="text-danger">*</span></label>
                                    <select asp-for="CategoryId" asp-items="Model.CategoryList" class="dmx-choices">
                                        <option value="">Select category</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small">Supplier</label>
                                    <select asp-for="SupplierId" asp-items="Model.SupplierList" class="dmx-choices">
                                        <option value="">Select supplier</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label small">Unit</label>
                                    <select asp-for="UnitId" asp-items="Model.UnitList" class="dmx-choices">
                                        <option value="">Select unit</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <label class="form-label small">Description</label>
                                    <textarea asp-for="Description" class="form-control dmx-textarea" rows="2"
                                              placeholder="Optional notes about this product"></textarea>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Pricing + Stock -->
                <div class="col-lg-4">

                    <div class="card shadow-sm mb-3">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Pricing</h6>
                        </div>
                        <div class="card-body">

                            <div class="did-floating-label-content mb-3">
                                <input asp-for="CostPrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" id="editCostPrice"
                                       placeholder=" " oninput="calcEditMargin()" />
                                <label class="did-floating-label">Cost price (GHS) <span class="text-danger">*</span></label>
                                <span asp-validation-for="CostPrice" class="text-danger small"></span>
                            </div>

                            <div class="did-floating-label-content mb-3">
                                <input asp-for="SellingPrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" id="editSellPrice"
                                       placeholder=" " oninput="calcEditMargin()" />
                                <label class="did-floating-label">Selling price (GHS) <span class="text-danger">*</span></label>
                                <span asp-validation-for="SellingPrice" class="text-danger small"></span>
                            </div>

                            <div class="did-floating-label-content mb-3">
                                <input asp-for="WholesalePrice" type="number" step="0.01" min="0"
                                       class="did-floating-input" placeholder=" " />
                                <label class="did-floating-label">Wholesale price (GHS)</label>
                            </div>

                            <div class="p-2 rounded bg-light text-center small">
                                Margin: <strong id="editMarginDisplay">—</strong>
                            </div>

                        </div>
                    </div>

                    <div class="card shadow-sm">
                        <div class="card-header bg-white border-0">
                            <h6 class="mb-0 fw-semibold">Stock settings</h6>
                        </div>
                        <div class="card-body">

                            <div class="did-floating-label-content mb-3">
                                <input asp-for="CurrentStock" type="number" min="0"
                                       class="did-floating-input" placeholder=" " />
                                <label class="did-floating-label">Current stock</label>
                            </div>

                            <div class="did-floating-label-content mb-3">
                                <input asp-for="ReorderLevel" type="number" min="0"
                                       class="did-floating-input" placeholder=" " />
                                <label class="did-floating-label">Reorder level</label>
                                <div class="form-text small">Alert when stock drops to this level.</div>
                            </div>

                            <div class="form-check mb-3">
                                <input asp-for="IsActive" type="checkbox" class="form-check-input" id="editIsActive" />
                                <label class="form-check-label" for="editIsActive">Active product</label>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button type="button" class="btn btn-secondary btn-sm"
                    onclick="document.getElementById('EditProductDialog').close()">
                Cancel
            </button>
            <button type="button" id="btnEditProduct" class="btn btn-primary btn-sm">
                <i class="fas fa-save me-1"></i> Update product
            </button>
        </div>
    }
</dialog>

<script>
    function calcEditMargin() {
        const cost = parseFloat(document.getElementById('editCostPrice').value) || 0;
        const sell = parseFloat(document.getElementById('editSellPrice').value) || 0;
        const el = document.getElementById('editMarginDisplay');
        if (sell > 0 && cost > 0) {
            const m = ((sell - cost) / sell * 100).toFixed(1);
            el.textContent = m + '%';
            el.style.color = m > 20 ? '#198754' : m > 10 ? '#fd7e14' : '#dc3545';
        } else {
            el.textContent = '—';
            el.style.color = '';
        }
    }

    document.getElementById('btnEditProduct').addEventListener('click', function () {
        const errors = [];

        const name = document.getElementById('Name').value.trim();
        const category = document.getElementById('CategoryId').value;
        const cost = parseFloat(document.getElementById('editCostPrice').value) || 0;
        const sell = parseFloat(document.getElementById('editSellPrice').value) || 0;

        if (!name)        errors.push('Product name is required.');
        if (!category)    errors.push('Please select a category.');
        if (cost <= 0)    errors.push('Cost price must be greater than 0.');
        if (sell <= 0)    errors.push('Selling price must be greater than 0.');

        if (errors.length > 0) {
            const list = document.getElementById('editProductErrorList');
            list.innerHTML = errors.map(e => `<li>${e}</li>`).join('');
            document.getElementById('editProductErrors').style.display = 'block';
            return;
        }

        document.getElementById('editProductErrors').style.display = 'none';

       @*  // pu.min / popup.js confirmation
        pu.confirm({
            title: 'Update product?',
            message: 'Are you sure you want to save these changes?',
            confirmText: 'Yes, update',
            cancelText: 'Cancel',
            onConfirm: function () {
                document.getElementById('editProductForm').submit();
            }
        });
    }); *@
        pujs.popup(
        'Update product?',               // title
        'Are you sure you want to save?', // message
        [
            {
                text: 'Yes, update',
                color: 'var(--blue)',
                callback: () => {
                    document.getElementById('editProductForm').submit();
                }
            },
            {
                text: 'Cancel',
                callback: () => { }   // empty callback — just closes
            }
        ],
        'horiz'   // button layout: 'horiz' or 'vert'
    );
    // Recalculate margin on load
    document.addEventListener('DOMContentLoaded', function () {
        calcEditMargin();
    });
</script>
