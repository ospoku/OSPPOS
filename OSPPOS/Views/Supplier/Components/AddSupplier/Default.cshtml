@model OSPPOS.ViewModels.AddSupplierVM;



<dialog id="AddSupplierDialog" style="position:fixed!important">
    <div class="">
        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-truck"></i> Add Supplier
        </h6>
        <button type="button" aria-label="Close"
                class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddSupplierDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddSupplier", "Supplier", FormMethod.Post, new { id = "addSupplierForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <!-- Name -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-building"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Name" type="text" class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Supplier Name <span class="text-danger">*</span></label>
                </div>
            </div>
            <span asp-validation-for="Name" class="text-danger small"></span>

            <!-- Phone -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-phone"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Phone" type="tel" class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Phone</label>
                </div>
            </div>

            <!-- Email -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-envelope"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Email" type="email" class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Email</label>
                </div>
            </div>
            <span asp-validation-for="Email" class="text-danger small"></span>

            <!-- Address -->
            <div class="input-group mb-3">
                <div class="input-group-text"><i class="fas fa-map-marker-alt"></i></div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Address" class="did-floating-input"
                              type="text" placeholder=" ">
                    <label class="did-floating-label">Address</label>
                </div>
            </div>

            <!-- Active -->
            <div class="form-check">
                <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActive" />
                <label class="form-check-label" for="isActive">Active supplier</label>
            </div>
        </div>

        <div class="modal-footer">
            <button type="submit" class="btn btn-primary btn-block">Save</button>
        </div>
    }
</dialog>

@if (!ViewContext.ModelState.IsValid)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("AddSupplierDialog").showModal();
        });
    </script>
}
    
          


  
