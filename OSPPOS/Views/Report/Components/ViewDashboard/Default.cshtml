@using OSPPOS.ViewModels
@{ 
    Layout = "~/Views/Shared/dashboard3.cshtml";
}
@model ViewDashboardVM

<div class="row">

    <!-- Earnings (Monthly) Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Documents
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800"><a asp-action="ViewDocuments" asp-controller="Document">@Model.TotalDocuments</a></div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Earnings (Monthly) Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Total Females
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalFemales</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Total Males
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalMales</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Earnings (Monthly) Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Tasks
                        </div>
                        <div class="row no-gutters align-items-center">
                            <div class="col-auto">
                                <div class="h5 mb-0 mr-3 font-weight-bold text-gray-800">50%</div>
                            </div>
                            <div class="col">
                                <div class="progress progress-sm mr-2">
                                    <div class="progress-bar bg-info" role="progressbar"
                                         style="width: 50%" aria-valuenow="50" aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clipboard-list fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pending Requests Card Example -->
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Pending Requests
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">18</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-comments fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <section class="stats-grid">
        <div class="stat-card"><div class="stat-title">Revenue</div><div class="stat-value">$12.4k</div><div class="stat-change"><i class="fas fa-arrow-up"></i> +8.2%</div></div>
        <div class="stat-card"><div class="stat-title">Orders</div><div class="stat-value">356</div><div class="stat-change"><i class="fas fa-arrow-up"></i> +12%</div></div>
        <div class="stat-card"><div class="stat-title">Visitors</div><div class="stat-value">2.1k</div><div class="stat-change"><i class="fas fa-arrow-down" style="color:#f28b82;"></i> -3.4%</div></div>
        <div class="stat-card"><div class="stat-title">Conversion</div><div class="stat-value">7.8%</div><div class="stat-change"><i class="fas fa-arrow-up"></i> +1.2%</div></div>
    </section>
    <div class="chart-placeholder">
        <div style="display: flex; justify-content: space-between;"><span>Weekly activity</span><span style="color:#8f9bb5;"><i class="far fa-calendar-alt"></i> Apr 20–26</span></div>
        <div class="chart-bar"><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div></div>
    </div>
    <div class="activity-list">
        <h4 style="margin-bottom: 0.5rem; font-weight: 500;"><i class="fas fa-stream" style="margin-right: 0.5rem;"></i>Recent activity</h4>
        <div class="activity-item"><i class="fas fa-user-plus"></i><span class="activity-text">New user <strong>Maria</strong> registered</span><span class="activity-time">2 min ago</span></div>
        <div class="activity-item"><i class="fas fa-shopping-cart"></i><span class="activity-text">Order #1024 shipped</span><span class="activity-time">1 hour ago</span></div>
        <div class="activity-item"><i class="fas fa-exclamation-triangle" style="color:#f5b86e;"></i><span class="activity-text">Server CPU warning</span><span class="activity-time">3 hours ago</span></div>
        <div class="activity-item"><i class="fas fa-check-circle" style="color:#7be0b0;"></i><span class="activity-text">Backup completed</span><span class="activity-time">6 hours ago</span></div>
    </div>
    <div style="height: 2rem;"></div>
      <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
                    <h4 class="fw-semibold mb-0"><i class="bi bi-house-door me-2"></i>Dashboard</h4>
                    <span class="text-dim-muted small"><i class="bi bi-clock me-1"></i>Last updated: today</span>
                </div> 

    <!-- stat cards -->
     <div class="row g-4 mb-4">
                    <div class="col-md-3 col-6"><div class="stat-card"><div class="text-dim-muted small">Revenue</div><h4 class="fw-bold mt-1">$12,430</h4><span class="badge bg-success bg-opacity-25 text-success">+8.2%</span></div></div>
                    <div class="col-md-3 col-6"><div class="stat-card"><div class="text-dim-muted small">Orders</div><h4 class="fw-bold mt-1">1,284</h4><span class="badge bg-info bg-opacity-25 text-info">+4.6%</span></div></div>
                    <div class="col-md-3 col-6"><div class="stat-card"><div class="text-dim-muted small">Visitors</div><h4 class="fw-bold mt-1">8,932</h4><span class="badge bg-warning bg-opacity-25 text-warning">+12.3%</span></div></div>
                    <div class="col-md-3 col-6"><div class="stat-card"><div class="text-dim-muted small">Tasks</div><h4 class="fw-bold mt-1">24</h4><span class="badge bg-secondary bg-opacity-25 text-dim-light">pending</span></div></div>
                </div> 

    <!-- activity + table -->
         <div class="row g-4">
                    <div class="col-lg-7">
                        <div class="stat-card p-3">
                            <h6 class="fw-semibold"><i class="bi bi-activity me-2"></i>Recent activity</h6>
                            <ul class="list-unstyled mt-2 small">
                                <li class="py-2 border-bottom border-dim"><i class="bi bi-circle-fill text-success me-2" style="font-size: 0.5rem;"></i>User #1024 updated profile</li>
                                <li class="py-2 border-bottom border-dim"><i class="bi bi-circle-fill text-warning me-2" style="font-size: 0.5rem;"></i>New order #4832 placed</li>
                                <li class="py-2 border-bottom border-dim"><i class="bi bi-circle-fill text-info me-2" style="font-size: 0.5rem;"></i>Server health check passed</li>
                                <li class="py-2"><i class="bi bi-circle-fill text-danger me-2" style="font-size: 0.5rem;"></i>Failed login attempt (blocked)</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <div class="stat-card p-3">
                            <h6 class="fw-semibold"><i class="bi bi-clock-history me-2"></i>Pending tasks</h6>
                            <div class="mt-2 d-flex flex-column gap-2">
                                <div class="d-flex justify-content-between"><span>Design review</span> <span class="badge badge-dim">2h</span></div>
                                <div class="d-flex justify-content-between"><span>Deploy build</span> <span class="badge badge-dim">4h</span></div>
                                <div class="d-flex justify-content-between"><span>Update docs</span> <span class="badge badge-dim">1d</span></div>
                            </div>
                        </div>
                    </div>
                </div> 
    <!-- extra dummy text to show scroll -->
       <div class="mt-4 text-dim-muted small" style="opacity:0.6;">
                    <hr class="border-dim">
                    <p class="mb-1"><i class="bi bi-dot"></i> Sticky header, footer, sidebar &amp; collapsible sidebar</p>
                    <p><i class="bi bi-dot"></i> Notifications &amp; Messages offcanvas · Shutdown dialog (HTML)</p>
                </div> 
</div>
