
@using DMX.Models;  
@using DMX.ViewComponents
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Web
@using Microsoft.AspNetCore.DataProtection
@using OSPPOS.Models
@using OSPPOS.ViewComponents
@inject UserManager<AppUser> usm;
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IEnumerable<OSPPOS.ViewModels.ViewSalesVM>;
@inject Microsoft.AspNetCore.DataProtection.IDataProtectionProvider DataProtectionProvider

@{
    // Optional: create protector in view (same purpose string)
    var protector = DataProtectionProvider.CreateProtector("IdProtector");
  
}

   
        <div class="tab-content tab-content-dim" id="myTabContent">
            <!-- TAB 1: USERS -->
            <div class="tab-pane fade show active tab-pane-dim" id="users" role="tabpanel">
                <div class="tab-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-semibold mb-0"><i class="bi bi-people me-2"></i>Sale Orders</h6>
                        <button class="btn btn-primary btn-sm" id="openFormBtn2" onclick="document.getElementById('AddSaleDialog').showModal()">
                            <i class="bi bi-plus-circle me-1"></i>Add Order
                        </button>
                    </div>     <div class="row g-2 mb-3">
                        <div class="col-sm-4">
                            <div class="card border-0 bg-success bg-opacity-10 text-success">
                                <div class="card-body py-2 px-3">
                                    <small>Total Revenue</small>
                                    <div class="fw-bold">@Model.Sum(o => o.TotalAmount).ToString("N2")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card border-0 bg-primary bg-opacity-10 text-primary">
                                <div class="card-body py-2 px-3">
                                    <small>Collected</small>
                                    <div class="fw-bold">@Model.Sum(o => o.AmountPaid).ToString("N2")</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="card border-0 bg-danger bg-opacity-10 text-danger">
                                <div class="card-body py-2 px-3">
                                    <small>Outstanding</small>
                                    <div class="fw-bold">@Model.Sum(o => o.AmountDue).ToString("N2")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- DATATABLES -->
                    <div class="table-container">
            <table class="table darkTable" id="saleOrdersTable">
                <thead>
                    <tr><th>SN</th>
                    <th>Customer</th>
                    <th>Order Number</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Amount</th>
                    <th>Paid</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                      @foreach (var sale in Model)
                {
                    <tr>
                        <td></td>

                        <td>@sale.CustomerName</td>
                        <td>@sale.OrderNumber</td>
                    <td>@sale.OrderDate</td>
                        <td>@sale.DueDate</td>
                        <td>@sale.SaleType</td>
                        <td>@sale.AmountDue</td>
                        <td>@sale.AmountPaid</td>
                        <td>@sale.CustomerId</td>
                      
                       

                           <td>

                        
                                    <div class="dropdown action-dropdown">
                                        <button class="dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            Select Action
                                        </button>
                                        <ul class="dropdown-menu">
    @if (sale.CanEdit)
                                            {
                                                <li><button class="dropdown-item" onclick="openDialogFromData(this)" data-url="EditSale" data-user-id="@protector.Protect(sale.PublicId.ToString())" data-dialog-id="EditMemoDialog" ><i class="bi bi-pencil text-primary"></i> Edit</button></li>
                                            }

    @if (sale.CanPrint)
                                            {
                                                <li>
                                                    <button class="dropdown-item" onclick="printMemoIframe('@protector.Protect(sale.PublicId.ToString())')><i class="bi bi-printer text-info">
                                                        
                                                Print </button></li >
                                            }
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item text-danger" href="#"><i class="bi bi-trash"></i> Delete</a></li>
                                        </ul>
                                    </div>
                        </td>
                    </tr>
             }
                </tbody>
            </table>
       </div>
       

   
    </div>
    </div>
    </div>
  

<iframe id="printFrame" style="display:none;"></iframe>
@section scripts{
<script type="text/javascript">
    function printMemoIframe(memoId) {
        const printFrame = document.getElementById('printFrame');
        printFrame.src = `/Memo/PrintMemo?Id=${memoId}`;
        printFrame.onload = function () {
            printFrame.contentWindow.focus();
            printFrame.contentWindow.print();
        };
    }
                  document.addEventListener("DOMContentLoaded", (function() {
                  $('#saleOrdersTable').DataTable({
                    pageLength: 5,
                    lengthMenu: [[5, 10, 25, 50, -1], [5, 10, 25, 50, "All"]],
                    order: [[4, 'desc']],
                    columnDefs: [
                      { orderable: false, targets: 5 }
                    ],
                    language: {
                      search: "Search:",
                      lengthMenu: "Show _MENU_ orders",
                      info: "Showing _START_ to _END_ of _TOTAL_ orders",
                      infoEmpty: "No order found",
                      infoFiltered: "(filtered from _MAX_ total orders)",
                      zeroRecords: "No order found"
                    },
                     dom: '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>' +
                       '<"row"<"col-sm-12"tr>>' +
                          '<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>'
                  })}))
</script>

}

@await Component.InvokeAsync(nameof(AddSale))
<dialog id="EditMemoDialog"><div id="EditMemoDialogContent"></div></dialog>
