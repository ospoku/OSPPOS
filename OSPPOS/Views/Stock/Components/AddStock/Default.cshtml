@model OSPPOS.ViewModels.AddStockVM

<dialog id="AddStockDialog" class="col-md-6 border-0 rounded p-0">
    <div class="modal-header">
        <h6 class="m-0 font-weight-bold d-inline">
            <i class="fas fa-fw fa-boxes"></i> Add Stock
        </h6>
        <button type="button" aria-label="Close"
                class="btn btn-sm btn-outline-danger"
                onclick="document.getElementById('AddStockDialog').close()">
            Close
        </button>
    </div>

    @using (Html.BeginForm("AddStock", "Stock", FormMethod.Post, new { id = "addStockForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <!-- Product -->
            <div class="mb-3">
                <select asp-for="ProductId" asp-items="Model.ProductList" class="dmx-choices">
                    <option value="">Select Product</option>
                </select>
                <span asp-validation-for="ProductId" class="text-danger small"></span>
            </div>

            <!-- Quantity -->
            <div class="input-group mb-3">
                <div class="input-group-text">
                    <i class="fas fa-cubes"></i>
                </div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Quantity" type="number" min="1"
                           class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Quantity <span class="text-danger">*</span></label>
                </div>
            </div>
            <span asp-validation-for="Quantity" class="text-danger small"></span>

            <!-- Cost Price -->
            <div class="input-group mb-3">
                <div class="input-group-text">
                    <i class="fas fa-tag"></i>
                </div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="CostPrice" type="number" step="0.01" min="0"
                           class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Cost Price (GHS)</label>
                </div>
            </div>
            <span asp-validation-for="CostPrice" class="text-danger small"></span>

            <!-- Supplier -->
            <div class="mb-3">
                <select asp-for="SupplierId" asp-items="Model.SupplierList" class="dmx-choices">
                    <option value="">Select Supplier (Optional)</option>
                </select>
            </div>

            <!-- Notes -->
            <div class="input-group mb-3">
                <div class="input-group-text">
                    <i class="fas fa-sticky-note"></i>
                </div>
                <div class="did-floating-label-content flex-grow-1">
                    <input asp-for="Notes" type="text"
                           class="did-floating-input" placeholder=" " />
                    <label class="did-floating-label">Notes / Reference</label>
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button type="submit" class="btn btn-primary btn-block">Save</button>
        </div>
    }
</dialog>

